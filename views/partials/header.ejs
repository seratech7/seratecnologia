<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MarketPlace</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

<header class="main-header">
  <div class="header-container">
    <div class="header-left">
      <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <a href="/" class="logo">
        <i class="fas fa-microchip"></i>
        <span>SeraTecnologia</span>
      </a>
    </div>
    <div class="header-center" id="searchContainer">
      <form action="/" method="GET" class="search-form">
        <i class="fas fa-search"></i>
        <input type="text" name="search" placeholder="Buscar HD, SSD, notebook..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">Buscar</button>
      </form>
    </div>
    <div class="header-right">
      <button class="search-toggle-mobile" id="searchToggle" aria-label="Buscar">
        <i class="fas fa-search"></i>
      </button>
      <% if (admin) { %>
        <a href="/admin/dashboard" class="btn-admin-header">
          <i class="fas fa-cog"></i>
          <span>Admin</span>
        </a>
      <% } else if (seller) { %>
        <a href="/seller/dashboard" class="btn-admin-header">
          <i class="fas fa-store-alt"></i>
          <span>Vendedor</span>
        </a>
      <% } else { %>
        <a href="/seller/login" class="btn-admin-header">
          <i class="fas fa-store-alt"></i>
          <span>Vender</span>
        </a>
      <% } %>
    </div>
  </div>
</header>

<div class="mobile-overlay" id="mobileOverlay"></div>
<nav class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-header">
    <a href="/" class="mobile-logo"><i class="fas fa-microchip"></i> SeraTecnologia</a>
    <button class="mobile-close" id="mobileClose">&times;</button>
  </div>
  <div class="mobile-menu-body">
    <form action="/" method="GET" class="mobile-search-form">
      <input type="text" name="search" placeholder="Buscar produtos..." value="<%= typeof search !== 'undefined' ? search : '' %>">
      <button type="submit"><i class="fas fa-search"></i></button>
    </form>
    <div class="mobile-nav-links">
      <a href="/"><i class="fas fa-home"></i> Início</a>
      <a href="#" class="mobile-sub-toggle" id="catToggle"><i class="fas fa-th-large"></i> Categorias <i class="fas fa-chevron-down"></i></a>
      <div class="mobile-submenu" id="catSubmenu">
        <a href="/">Todas</a>
        <a href="/?category=ssds">⚡ SSDs</a>
        <a href="/?category=hds-armazenamento">💾 HDs</a>
        <a href="/?category=memoria-ram">🧠 Memória RAM</a>
        <a href="/?category=processadores">🔲 Processadores</a>
        <a href="/?category=placas-video">🎮 Placas de Vídeo</a>
        <a href="/?category=placas-mae">🔧 Placas-mãe</a>
      </div>
      <% if (admin) { %>
        <a href="/admin/dashboard"><i class="fas fa-cog"></i> Painel Admin</a>
      <% } else if (seller) { %>
        <a href="/seller/dashboard"><i class="fas fa-store-alt"></i> Painel Vendedor</a>
      <% } else { %>
        <a href="/seller/login"><i class="fas fa-store-alt"></i> Quero Vender</a>
      <% } %>
    </div>
  </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var hamburger = document.getElementById('hamburgerBtn');
  var mobileMenu = document.getElementById('mobileMenu');
  var overlay = document.getElementById('mobileOverlay');
  var closeBtn = document.getElementById('mobileClose');
  var searchToggle = document.getElementById('searchToggle');
  var searchContainer = document.getElementById('searchContainer');
  var catToggle = document.getElementById('catToggle');
  var catSubmenu = document.getElementById('catSubmenu');

  if (hamburger && mobileMenu && overlay) {
    function openMenu() {
      hamburger.classList.add('active');
      mobileMenu.classList.add('active');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      hamburger.classList.remove('active');
      mobileMenu.classList.remove('active');
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }
    hamburger.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);
  }

  if (searchToggle && searchContainer) {
    searchToggle.addEventListener('click', function() {
      searchContainer.classList.toggle('active');
      if (searchContainer.classList.contains('active')) {
        var input = searchContainer.querySelector('input');
        if (input) input.focus();
      }
    });
  }

  if (catToggle && catSubmenu) {
    catToggle.addEventListener('click', function(e) {
      e.preventDefault();
      catSubmenu.classList.toggle('active');
      catToggle.querySelector('.fa-chevron-down').classList.toggle('rotated');
    });
  }
});
</script>

<div class="top-ad" id="topAd">
  <div class="top-ad-content">
    <span class="top-ad-label">PUBLICIDADE</span>
    <span class="top-ad-text" id="adText"></span>
  </div>
  <button class="top-ad-close" id="adClose" aria-label="Fechar">&times;</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var ads = [
    '<i class="fas fa-bolt"></i> SSD Kingston NV2 1TB — R$ 349,90. <a href="/produto/1">Ver oferta</a>',
    '<i class="fas fa-microchip"></i> Memória DDR5 32GB — R$ 589,90. <a href="/produto/4">Compre agora</a>',
    '<i class="fas fa-hdd"></i> HD Seagate 2TB — R$ 289,90. <a href="/produto/2">Aproveite</a>',
    '<i class="fas fa-star"></i> SSD Samsung 990 Pro 2TB — R$ 1.299,90. <a href="/produto/15">Oferta especial</a>'
  ];

  var adText = document.getElementById('adText');
  var adClose = document.getElementById('adClose');
  var topAd = document.getElementById('topAd');

  if (adText && !localStorage.getItem('adClosed')) {
    adText.innerHTML = ads[Math.floor(Math.random() * ads.length)];
  }

  if (adClose && topAd) {
    adClose.addEventListener('click', function() {
      topAd.style.display = 'none';
      localStorage.setItem('adClosed', '1');
    });
  }
});
</script>

<main class="main-content" style="padding-top: 72px; min-height: 100vh;">
