<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MarketPlace</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/fonts/fontawesome.min.css">
</head>
<body class="admin-page">

<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-brand">
      <a href="/admin/dashboard">
        <i class="fas fa-microchip"></i>
        <span>SeraTecnologia</span>
      </a>
      <span class="sidebar-subtitle">Painel Admin</span>
    </div>

    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="<%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <i class="fas fa-tachometer-alt"></i> Dashboard
      </a>
      <a href="/admin/products" class="<%= currentPath.startsWith('/admin/products') ? 'active' : '' %>">
        <i class="fas fa-box"></i> Produtos
      </a>
      <a href="/admin/products?filter=featured" style="color:#ffd700;">
        <i class="fas fa-star"></i> Destaques
      </a>
      <a href="/admin/sellers" class="<%= currentPath === '/admin/sellers' ? 'active' : '' %>">
        <i class="fas fa-store-alt"></i> Vendedores
      </a>
      <a href="/admin/categories" class="<%= currentPath === '/admin/categories' ? 'active' : '' %>">
        <i class="fas fa-tags"></i> Categorias
      </a>
      <a href="/admin/admins" class="<%= currentPath === '/admin/admins' ? 'active' : '' %>">
        <i class="fas fa-users-cog"></i> Admins
      </a>
      <a href="/admin/ads" class="<%= currentPath.startsWith('/admin/ads') ? 'active' : '' %>">
        <i class="fas fa-ad"></i> Anúncios
      </a>
      <a href="/admin/sales" class="<%= currentPath.startsWith('/admin/sales') ? 'active' : '' %>">
        <i class="fas fa-shopping-bag"></i> Vendas
      </a>
      <a href="/admin/ofertas" class="<%= currentPath.startsWith('/admin/ofertas') ? 'active' : '' %>">
        <i class="fas fa-bolt"></i> Ofertas
      </a>
      <a href="/admin/analytics" class="<%= currentPath.startsWith('/admin/analytics') ? 'active' : '' %>">
        <i class="fas fa-chart-line"></i> Analytics
      </a>
      <a href="/admin/reviews" class="<%= currentPath.startsWith('/admin/reviews') ? 'active' : '' %>">
        <i class="fas fa-star"></i> Avaliações
      </a>
      <a href="/admin/notifications" class="<%= currentPath.startsWith('/admin/notifications') ? 'active' : '' %>">
        <i class="fas fa-bell"></i> Notificações
      </a>
      <a href="/admin/financeiro" class="<%= currentPath.startsWith('/admin/financeiro') ? 'active' : '' %>">
        <i class="fas fa-coins"></i> Financeiro
      </a>
      <a href="/admin/paginas" class="<%= currentPath.startsWith('/admin/paginas') ? 'active' : '' %>">
        <i class="fas fa-file-alt"></i> Páginas
      </a>
      <a href="/admin/cupons" class="<%= currentPath === '/admin/cupons' ? 'active' : '' %>">
        <i class="fas fa-ticket-alt"></i> Cupons
      </a>
      <a href="/admin/banners" class="<%= currentPath === '/admin/banners' ? 'active' : '' %>">
        <i class="fas fa-images"></i> Banners
      </a>
      <a href="/admin/metas" class="<%= currentPath === '/admin/metas' ? 'active' : '' %>">
        <i class="fas fa-bullseye"></i> Metas
      </a>
      <a href="/admin/placar" class="<%= currentPath === '/admin/placar' ? 'active' : '' %>">
        <i class="fas fa-ranking-star"></i> Placar
      </a>
      <a href="/admin/toggles" class="<%= currentPath === '/admin/toggles' ? 'active' : '' %>">
        <i class="fas fa-toggle-on"></i> Toggles
      </a>
      <a href="/admin/marketing" class="<%= (currentPath || '').startsWith('/admin/marketing') ? 'active' : '' %>">
        <i class="fas fa-bullhorn"></i> Marketing
      </a>
      <a href="/admin/whatsapp" class="<%= (currentPath || '').startsWith('/admin/whatsapp') ? 'active' : '' %>">
        <i class="fas fa-comment-dots"></i> WhatsApp
      </a>
      <a href="/admin/blast" class="<%= currentPath === '/admin/blast' ? 'active' : '' %>">
        <i class="fas fa-bullhorn"></i> Notificar Todos
      </a>
      <a href="/admin/limpar" class="<%= currentPath === '/admin/limpar' ? 'active' : '' %>">
        <i class="fas fa-broom"></i> Limpar Dados
      </a>
      <a href="/admin/logs" class="<%= currentPath === '/admin/logs' ? 'active' : '' %>">
        <i class="fas fa-history"></i> Logs
      </a>
      <a href="/admin/ips-bloqueados" class="<%= currentPath === '/admin/ips-bloqueados' ? 'active' : '' %>">
        <i class="fas fa-ban"></i> IPs Bloqueados
      </a>
      <a href="/admin/config" class="<%= currentPath === '/admin/config' ? 'active' : '' %>">
        <i class="fas fa-cog"></i> Configurações
      </a>
      <% if (!admin && seller) { %>
      <a href="/seller/sales" class="<%= currentPath === '/seller/sales' ? 'active' : '' %>">
        <i class="fas fa-shopping-bag"></i> Vendas
      </a>
      <a href="/seller/coupons" class="<%= currentPath === '/seller/coupons' ? 'active' : '' %>">
        <i class="fas fa-ticket-alt"></i> Cupons
      </a>
      <a href="/seller/wallet" class="<%= currentPath === '/seller/wallet' ? 'active' : '' %>">
        <i class="fas fa-wallet"></i> Carteira
      </a>
      <% } %>
    </nav>

    <div class="sidebar-footer">
      <a href="/" target="_blank" class="sidebar-link">
        <i class="fas fa-external-link-alt"></i> Ver Site
      </a>
      <a href="/admin/logout" class="sidebar-link logout">
        <i class="fas fa-sign-out-alt"></i> Sair
      </a>
    </div>
  </aside>

  <div class="admin-main">
