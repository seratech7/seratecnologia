<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MarketPlace</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="admin-page">

<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-brand">
      <a href="/admin/dashboard">
        <i class="fas fa-microchip"></i>
        <span>SeraTecnologia</span>
      </a>
      <span class="sidebar-subtitle">Painel Admin</span>
    </div>

    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="<%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <i class="fas fa-tachometer-alt"></i> Dashboard
      </a>
      <a href="/admin/products" class="<%= currentPath.startsWith('/admin/products') ? 'active' : '' %>">
        <i class="fas fa-box"></i> Produtos
      </a>
      <a href="/admin/products?filter=featured" style="color:#ffd700;">
        <i class="fas fa-star"></i> Destaques
      </a>
      <a href="/admin/sellers" class="<%= currentPath === '/admin/sellers' ? 'active' : '' %>">
        <i class="fas fa-store-alt"></i> Vendedores
      </a>
      <a href="/admin/categories" class="<%= currentPath === '/admin/categories' ? 'active' : '' %>">
        <i class="fas fa-tags"></i> Categorias
      </a>
      <a href="/admin/admins" class="<%= currentPath === '/admin/admins' ? 'active' : '' %>">
        <i class="fas fa-users-cog"></i> Admins
      </a>
      <a href="/admin/ads" class="<%= currentPath.startsWith('/admin/ads') ? 'active' : '' %>">
        <i class="fas fa-ad"></i> Anúncios
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="/" target="_blank" class="sidebar-link">
        <i class="fas fa-external-link-alt"></i> Ver Site
      </a>
      <a href="/admin/logout" class="sidebar-link logout">
        <i class="fas fa-sign-out-alt"></i> Sair
      </a>
    </div>
  </aside>

  <div class="admin-main">
