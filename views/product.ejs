<%- include('partials/header') %>

<div class="product-detail-container">
  <div class="breadcrumb">
    <a href="/"><i class="fas fa-home"></i> Início</a>
    <% if (product.category_name) { %>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/?category=<%= product.category_name.toLowerCase().replace(/ /g, '-') %>"><%= product.category_icon %> <%= product.category_name %></a>
    <% } %>
    <span><i class="fas fa-chevron-right"></i></span>
    <span><%= product.name %></span>
  </div>

  <div class="product-detail-content">
    <div class="product-gallery">
      <% if (product.image) { %>
        <div class="main-image">
          <img src="<%= product.image %>" alt="<%= product.name %>">
        </div>
      <% } else { %>
        <div class="main-image no-image-big">
          <i class="fas fa-image"></i>
          <p>Sem imagem</p>
        </div>
      <% } %>
    </div>

    <div class="product-detail-info">
      <div class="product-header-info">
        <h1><%= product.name %></h1>
        <p class="product-price-large">
          <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(product.price) %>
        </p>
        <a href="/comprar?codigo=<%= product.code || 'PROD-' + String(product.id).padStart(5, '0') %>" class="btn-comprar-agora">
          <i class="fas fa-shopping-cart"></i> Comprar Agora
        </a>
      </div>

      <div class="product-badges">
        <% if (product.featured) { %>
          <span class="badge badge-featured"><i class="fas fa-star"></i> Destaque</span>
        <% } %>
        <span class="badge <%= product.condition === 'new' ? 'badge-new' : product.condition === 'semi-new' ? 'badge-semi' : 'badge-used' %>">
          <%= product.condition === 'new' ? 'Novo' : product.condition === 'semi-new' ? 'Semi-novo' : 'Usado' %>
        </span>
      </div>

      <div class="product-attributes">
        <div class="attribute">
          <i class="fas fa-map-marker-alt"></i>
          <div>
            <span class="attr-label">Localização</span>
            <span class="attr-value"><%= product.location || 'Brasil' %></span>
          </div>
        </div>
        <div class="attribute">
          <i class="fas fa-tag"></i>
          <div>
            <span class="attr-label">Categoria</span>
            <span class="attr-value"><%= product.category_icon || '' %> <%= product.category_name || 'Sem categoria' %></span>
          </div>
        </div>
        <div class="attribute">
          <i class="fas fa-barcode"></i>
          <div>
            <span class="attr-label">Código</span>
            <span class="attr-value"><%= product.code || 'PROD-' + String(product.id).padStart(5, '0') %></span>
          </div>
        </div>
        <div class="attribute">
          <i class="fas fa-calendar"></i>
          <div>
            <span class="attr-label">Anunciado em</span>
            <span class="attr-value"><%= new Date(product.created_at).toLocaleDateString('pt-BR') %></span>
          </div>
        </div>
        <div class="attribute">
          <i class="fas fa-eye"></i>
          <div>
            <span class="attr-label">Visualizações</span>
            <span class="attr-value"><%= product.views || 0 %></span>
          </div>
        </div>
        <div class="attribute">
          <i class="fas fa-shopping-cart"></i>
          <div>
            <span class="attr-label">Vendas</span>
            <span class="attr-value"><%= product.sales_count || 0 %></span>
          </div>
        </div>
      </div>

      <div class="product-description">
        <h3>Descrição</h3>
        <p><%= product.description || 'Nenhuma descrição fornecida.' %></p>
      </div>

      <% if (seller) { %>
        <div class="seller-card">
          <h3><i class="fas fa-store"></i> Vendedor</h3>
          <a href="/vendedor/<%= seller.id %>" class="seller-card-content">
            <div class="seller-avatar-mini">
              <% if (seller.avatar) { %>
                <img src="<%= seller.avatar %>" alt="<%= seller.name %>">
              <% } else { %>
                <div class="avatar-placeholder-mini"><i class="fas fa-store"></i></div>
              <% } %>
            </div>
            <div class="seller-card-info">
              <strong><%= seller.name %></strong>
              <span><i class="fas fa-shopping-cart"></i> <%= seller.sales_count || 0 %> vendas</span>
            </div>
            <i class="fas fa-chevron-right seller-card-arrow"></i>
          </a>
        </div>
      <% } %>

      <div class="product-ratings">
        <h3><i class="fas fa-star"></i> Avaliações</h3>

        <div class="rating-summary">
          <div class="rating-stars-large">
            <% const avg = rating && rating.count > 0 ? Math.round(rating.avg * 2) / 2 : 0; %>
            <% const fullStars = Math.floor(avg); %>
            <% const halfStar = avg - fullStars >= 0.5; %>
            <% for (let i = 1; i <= 5; i++) { %>
              <i class="fas fa-star <%= i <= fullStars ? 'star-filled' : (i === fullStars + 1 && halfStar ? 'star-half' : 'star-empty') %>"></i>
            <% } %>
            <span class="rating-number"><%= avg %></span>
            <span class="rating-count">(<%= rating ? rating.count : 0 %> avaliações)</span>
          </div>
        </div>

        <div class="rating-form">
          <h4>Avaliar este produto</h4>
          <form action="/produto/<%= product.id %>/avaliar" method="POST" class="star-rating-form">
            <div class="star-input">
              <select name="rating" id="rating-select" required>
                <option value="">Selecione</option>
                <option value="5">5 estrelas</option>
                <option value="4">4 estrelas</option>
                <option value="3">3 estrelas</option>
                <option value="2">2 estrelas</option>
                <option value="1">1 estrela</option>
              </select>
            </div>
            <textarea name="comment" placeholder="Seu comentário (opcional)" rows="2" maxlength="500"></textarea>
            <button type="submit" class="btn-contact"><i class="fas fa-star"></i> Avaliar</button>
          </form>
        </div>

        <% if (reviews && reviews.length > 0) { %>
          <div class="reviews-list">
            <% reviews.forEach(r => { %>
              <div class="review-item">
                <div class="review-stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <i class="fas fa-star <%= i <= r.rating ? 'star-filled' : 'star-empty' %>"></i>
                  <% } %>
                  <span class="review-date"><%= new Date(r.created_at).toLocaleDateString('pt-BR') %></span>
                </div>
                <% if (r.comment) { %><p class="review-comment"><%= r.comment %></p><% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="contact-seller">
        <h3><i class="fas fa-comment"></i> Entrar em contato</h3>
        <p>Interessado neste produto? Entre em contato com o vendedor.</p>
        <button class="btn-contact" onclick="alert('Funcionalidade de chat em desenvolvimento')">
          <i class="fas fa-envelope"></i> Enviar mensagem
        </button>
      </div>
    </div>
  </div>

  <% if (related.length > 0) { %>
    <div class="related-products">
      <h3><i class="fas fa-tags"></i> Produtos Relacionados</h3>
      <div class="products-grid related-grid">
        <% related.forEach(product => { %>
          <a href="/produto/<%= product.id %>" class="product-card">
            <div class="product-image">
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>">
              <% } else { %>
                <div class="no-image"><i class="fas fa-image"></i></div>
              <% } %>
            </div>
            <div class="product-info">
              <h3 class="product-name"><%= product.name %></h3>
              <p class="product-price"><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(product.price) %></p>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
