<%- include('../partials/admin-header', { title: title, currentPath: '/admin/banners' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-images"></i> Banners da Home</h1>
  </div>
  <div class="form-card" style="margin-bottom:20px;">
    <h3>Novo Banner</h3>
    <form method="POST" action="/admin/banners/novo" enctype="multipart/form-data" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div class="form-group"><label>Título</label><input type="text" name="title" class="admin-input"></div>
      <div class="form-group"><label>Subtítulo</label><input type="text" name="subtitle" class="admin-input"></div>
      <div class="form-group"><label>Link</label><input type="text" name="link" class="admin-input" placeholder="https://..."></div>
      <div class="form-group"><label>Ordem</label><input type="number" name="sort_order" class="admin-input" value="0" min="0"></div>
      <div class="form-group" style="grid-column:1/-1;"><label>Imagem *</label><input type="file" name="image" accept="image/*" required></div>
      <div class="form-group" style="grid-column:1/-1;"><label style="display:flex;align-items:center;gap:8px;"><input type="checkbox" name="active" value="1" checked> Ativo</label></div>
      <div style="grid-column:1/-1;"><button type="submit" class="btn-primary"><i class="fas fa-plus"></i> Adicionar Banner</button></div>
    </form>
  </div>
  <div class="table-wrapper">
    <table class="admin-table">
      <thead><tr><th>Imagem</th><th>Título</th><th>Ordem</th><th>Status</th><th>Ações</th></tr></thead>
      <tbody>
        <% if (banners.length === 0) { %><tr><td colspan="5" class="empty-row">Nenhum banner</td></tr><% } %>
        <% banners.forEach(function(b) { %>
          <tr>
            <td><img src="<%= b.image %>" style="width:120px;height:60px;object-fit:cover;border-radius:4px;"></td>
            <td><strong><%= b.title || '-' %></strong><% if (b.subtitle) { %><br><span style="font-size:12px;color:#999;"><%= b.subtitle %></span><% } %></td>
            <td><%= b.sort_order %></td>
            <td><span class="status-badge <%= b.active ? 'active' : 'inactive' %>"><%= b.active ? 'Ativo' : 'Inativo' %></span></td>
            <td>
              <form method="POST" action="/admin/banners/editar/<%= b.id %>" enctype="multipart/form-data" style="display:flex;gap:4px;flex-wrap:wrap;align-items:center;">
                <input type="text" name="title" value="<%= b.title %>" style="width:80px;padding:4px;border:1px solid #ddd;border-radius:4px;font-size:11px;">
                <input type="text" name="subtitle" value="<%= b.subtitle %>" style="width:80px;padding:4px;border:1px solid #ddd;border-radius:4px;font-size:11px;">
                <input type="number" name="sort_order" value="<%= b.sort_order %>" style="width:50px;padding:4px;border:1px solid #ddd;border-radius:4px;font-size:11px;">
                <input type="file" name="image" accept="image/*" style="width:80px;font-size:11px;">
                <label style="font-size:11px;"><input type="checkbox" name="active" value="1" <%= b.active ? 'checked' : %>> Ativo</label>
                <button class="btn-icon" style="font-size:11px;padding:4px;" title="Salvar"><i class="fas fa-save"></i></button>
              </form>
              <form method="POST" action="/admin/banners/deletar/<%= b.id %>" style="display:inline;" onsubmit="return confirm('Excluir banner?')">
                <button class="btn-icon" style="font-size:11px;padding:4px;color:#c62828;" title="Excluir"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/admin-footer') %>