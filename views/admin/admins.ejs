<%- include('../partials/admin-header') %>

<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-users-cog"></i> Administradores</h1>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="form-card">
    <h3><i class="fas fa-user-plus"></i> Novo Administrador</h3>
    <form action="/admin/admins/new" method="POST" class="admin-form">
      <div class="form-row">
        <div class="form-group">
          <input type="text" name="username" placeholder="Nome de usuário" required>
        </div>
        <div class="form-group">
          <input type="text" name="display_name" placeholder="Nome de exibição">
        </div>
        <div class="form-group">
          <input type="password" name="password" placeholder="Senha" required>
        </div>
        <button type="submit" class="btn-primary"><i class="fas fa-plus"></i> Adicionar</button>
      </div>
    </form>
  </div>

  <div class="table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Usuário</th>
          <th>Nome</th>
          <th>Criado em</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% admins.forEach(a => { %>
          <tr>
            <td><%= a.id %></td>
            <td><strong><%= a.username %></strong></td>
            <td><%= a.display_name %></td>
            <td><%= new Date(a.created_at).toLocaleDateString('pt-BR') %></td>
            <td>
              <% if (a.id !== session.adminId) { %>
                <form action="/admin/admins/delete/<%= a.id %>" method="POST" class="inline-form" onsubmit="return confirm('Excluir este administrador?')">
                  <button type="submit" class="btn-icon btn-delete" title="Excluir"><i class="fas fa-trash"></i></button>
                </form>
              <% } else { %>
                <span class="current-user-badge">Você</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/admin-footer') %>
