<%- include('../partials/admin-header') %>

<div class="dashboard-header">
  <h1><i class="fas fa-coins"></i> Financeiro</h1>
  <p>Controle de comissões e saldo dos vendedores</p>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px;">
  <div style="background:linear-gradient(135deg,#1565c0,#0d47a1);color:#fff;border-radius:12px;padding:20px;">
    <div style="font-size:13px;opacity:0.8;">Total em Vendas</div>
    <div style="font-size:26px;font-weight:800;margin-top:4px;">
      <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(totalVendas) %>
    </div>
  </div>
  <div style="background:linear-gradient(135deg,#e65100,#bf360c);color:#fff;border-radius:12px;padding:20px;">
    <div style="font-size:13px;opacity:0.8;">Total Comissões</div>
    <div style="font-size:26px;font-weight:800;margin-top:4px;">
      <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(totalComissoes) %>
    </div>
  </div>
  <div style="background:#fff;border-radius:12px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <div style="font-size:13px;color:#666;">Comissão Atual</div>
    <div style="font-size:26px;font-weight:800;color:#1565c0;margin-top:4px;"><%= commPct %>%</div>
    <form method="POST" action="/admin/financeiro/comissao" style="display:flex;gap:4px;margin-top:8px;">
      <input type="number" name="commission_pct" value="<%= commPct %>" min="0" max="100" step="0.5" style="width:70px;padding:4px 8px;border:1px solid #ddd;border-radius:4px;font-size:13px;">
      <button type="submit" class="btn-small" style="padding:4px 10px;font-size:12px;">Alterar</button>
    </form>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">
  <div style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:20px;">
    <h3 style="margin:0 0 12px;font-size:16px;"><i class="fas fa-store"></i> Saldo dos Vendedores</h3>
    <div style="overflow-x:auto;">
    <table class="admin-table" style="font-size:13px;">
      <thead><tr><th>Vendedor</th><th>Vendas</th><th>Saldo</th></tr></thead>
      <tbody>
        <% allSellers.forEach(function(s) { %>
        <tr>
          <td><%= s.name %></td>
          <td><%= s.sales_count %></td>
          <td style="font-weight:700;color:<%= s.balance >= 0 ? '#2e7d32' : '#c62828' %>;">
            <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(s.balance || 0) %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  </div>

  <div style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:20px;">
    <h3 style="margin:0 0 12px;font-size:16px;"><i class="fas fa-adjust"></i> Ajuste Manual</h3>
    <form method="POST" action="/admin/financeiro/ajuste">
      <div style="margin-bottom:8px;">
        <select name="seller_id" required style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
          <option value="">Selecione o vendedor</option>
          <% allSellers.forEach(function(s) { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:8px;">
        <input type="number" name="amount" step="0.01" placeholder="Valor (+/-)" required style="flex:1;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
      </div>
      <div style="margin-bottom:8px;">
        <input type="text" name="description" placeholder="Descrição do ajuste" required style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
      </div>
      <button type="submit" class="btn-small" style="background:var(--primary);color:#fff;width:100%;justify-content:center;"><i class="fas fa-save"></i> Aplicar Ajuste</button>
    </form>
  </div>
</div>

<div style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:20px;margin-bottom:20px;">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:16px;">
    <h3 style="margin:0;font-size:16px;"><i class="fas fa-history"></i> Histórico de Transações</h3>
    <form method="GET" action="/admin/financeiro" style="display:flex;gap:4px;">
      <input type="text" name="search" value="<%= search %>" placeholder="Buscar por vendedor..." style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
      <button type="submit" class="btn-small" style="font-size:12px;"><i class="fas fa-search"></i></button>
    </form>
  </div>
  <div style="overflow-x:auto;">
  <table class="admin-table">
    <thead><tr><th>Data</th><th>Vendedor</th><th>Descrição</th><th>Tipo</th><th>Valor</th><th>Saldo</th></tr></thead>
    <tbody>
      <% if (txns.length === 0) { %>
      <tr><td colspan="6" style="text-align:center;padding:20px;color:#999;">Nenhuma transação</td></tr>
      <% } %>
      <% txns.forEach(function(t) { %>
      <tr>
        <td style="font-size:12px;color:#666;white-space:nowrap;"><%= t.created_at %></td>
        <td><%= t.seller_name || 'Admin' %></td>
        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= t.description %></td>
        <td>
          <% if (t.type === 'sale') { %><span style="background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:4px;font-size:12px;">Venda</span>
          <% } else if (t.type === 'commission') { %><span style="background:#fff3e0;color:#e65100;padding:2px 8px;border-radius:4px;font-size:12px;">Comissão</span>
          <% } else if (t.type === 'adjustment') { %><span style="background:#e3f2fd;color:#1565c0;padding:2px 8px;border-radius:4px;font-size:12px;">Ajuste</span>
          <% } else { %><span style="background:#f5f5f5;color:#666;padding:2px 8px;border-radius:4px;font-size:12px;"><%= t.type %></span><% } %>
        </td>
        <td style="font-weight:700;color:<%= t.amount >= 0 ? '#2e7d32' : '#c62828' %>;">
          <%= t.amount >= 0 ? '+' : '' %><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(t.amount) %>
        </td>
        <td><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(t.balance || 0) %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  </div>
  <% if (totalPages > 1) { %>
  <div style="display:flex;gap:8px;justify-content:center;margin-top:20px;">
    <% for(var p=1;p<=totalPages;p++){ %>
      <a href="/admin/financeiro?page=<%= p %><%= search ? '&search='+search : '' %>" class="btn-small" style="<%= p===page?'background:var(--primary);color:#fff;':'' %>min-width:36px;text-align:center;text-decoration:none;"><%= p %></a>
    <% } %>
  </div>
  <% } %>
</div>

<%- include('../partials/admin-footer') %>