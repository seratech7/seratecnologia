<%- include('../partials/admin-header') %>

<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-tags"></i> Categorias</h1>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="form-card">
    <h3><i class="fas fa-plus"></i> Nova Categoria</h3>
    <form action="/admin/categories/new" method="POST" class="admin-form inline-form-row">
      <div class="form-row">
        <div class="form-group">
          <input type="text" name="name" placeholder="Nome da categoria" required>
        </div>
        <div class="form-group">
          <input type="text" name="icon" placeholder="Ícone (emoji)" value="📦">
        </div>
        <button type="submit" class="btn-primary"><i class="fas fa-plus"></i> Adicionar</button>
      </div>
    </form>
  </div>

  <div class="table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Ícone</th>
          <th>Nome</th>
          <th>Slug</th>
          <th>Produtos</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% categories.forEach(cat => { %>
          <tr>
            <td class="icon-cell"><%= cat.icon || '📦' %></td>
            <td><%= cat.name %></td>
            <td><code><%= cat.slug %></code></td>
            <td><%= cat.product_count || 0 %></td>
            <td>
              <form action="/admin/categories/delete/<%= cat.id %>" method="POST" class="inline-form" onsubmit="return confirm('Excluir esta categoria? Os produtos serão removidos da categoria.')">
                <button type="submit" class="btn-icon btn-delete" title="Excluir"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/admin-footer') %>
