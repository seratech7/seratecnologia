<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/discord' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fab fa-discord"></i> Discord</h1>
    <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
  </div>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="card" style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;gap:10px;">
      <span style="font-size:28px;"><%= webhookUrl ? '🟢' : '🔴' %></span>
      <div><strong style="font-size:16px;"><%= webhookUrl ? 'Discord Configurado' : 'Discord Não Configurado' %></strong>
      <span style="font-size:12px;color:#666;display:block;"><%= webhookUrl ? 'Webhook ativo' : 'Configure DISCORD_WEBHOOK_URL no .env' %></span></div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="form-card">
      <h3><i class="fas fa-paper-plane"></i> Enviar Mensagem</h3>
      <% if (templates.length > 0) { %>
      <div style="margin-bottom:8px;display:flex;flex-wrap:wrap;gap:4px;">
        <% templates.forEach(function(t) { %>
          <button type="button" class="tchip" onclick="document.querySelector('[name=message]').value='<%= t.content.replace(/'/g,"\\'").replace(/\n/g,'\\n') %>'"><%= t.name %></button>
        <% }) %>
      </div>
      <% } %>
      <form method="POST" action="/admin/marketing/discord/send">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group"><label>Mensagem</label><textarea name="message" class="admin-input" rows="6" required placeholder="Digite a mensagem..."></textarea></div>
        <button type="submit" class="btn-primary" <%= webhookUrl ? '' : 'disabled' %>><i class="fab fa-discord"></i> Enviar</button>
      </form>
    </div>
    <div>
      <div class="card" style="margin-bottom:15px;">
        <h3><i class="fas fa-cog"></i> Configuração</h3>
        <div style="background:#f5f5f5;padding:12px;border-radius:6px;font-family:monospace;font-size:12px;word-break:break-all;margin:10px 0;">
          DISCORD_WEBHOOK_URL=<%= webhookUrl || 'sua_webhook_url' %>
        </div>
        <details style="font-size:13px;">
          <summary style="cursor:pointer;color:#666;">Como criar um Webhook</summary>
          <ol style="font-size:12px;line-height:1.8;margin:8px 0 0 16px;padding:0;">
            <li>Abra seu servidor Discord > Configurações</li>
            <li>Integrações > Webhooks > Novo Webhook</li>
            <li>Copie a URL e cole no <code>.env</code></li>
          </ol>
        </details>
      </div>
      <div class="card">
        <h3><i class="fas fa-plug"></i> Testar Conexão</h3>
        <p style="font-size:13px;color:#666;">Verifica se a URL do webhook é válida</p>
        <button type="button" class="btn-secondary" onclick="testDiscord()">Testar Webhook</button>
        <div id="discordTestResult" style="margin-top:8px;font-size:13px;"></div>
      </div>
    </div>
  </div>
</div>
<script>
async function testDiscord() {
  const el = document.getElementById('discordTestResult');
  el.innerHTML = '<span style="color:#999;">Testando...</span>';
  try {
    const r = await fetch('/admin/marketing/discord/test', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' } });
    const d = await r.json();
    el.innerHTML = d.ok ? '<span style="color:#2e7d32;">✅ Webhook válido</span>' : '<span style="color:#c62828;">❌ ' + (d.error||'Erro') + '</span>';
  } catch(e) { el.innerHTML = '<span style="color:#c62828;">Erro: ' + e.message + '</span>'; }
}
</script>
<style>
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
.tchip { background:#f0f9ff; border:1px solid #bae6fd; border-radius:14px; padding:3px 10px; font-size:11px; color:#0369a1; cursor:pointer; }
.tchip:hover { background:#e0f2fe; }
</style>
<%- include('../../partials/admin-footer') %>
