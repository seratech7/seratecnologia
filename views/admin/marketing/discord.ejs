<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/discord' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fab fa-discord"></i> Discord</h1>
    <a href="/admin/marketing" class="btn-secondary" style="float:right;"><i class="fas fa-arrow-left"></i> Voltar</a>
  </div>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="form-card">
      <h3><i class="fas fa-paper-plane"></i> Enviar Mensagem</h3>
      <form method="POST" action="/admin/marketing/discord/send">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group"><label>Mensagem</label><textarea name="message" class="admin-input" rows="6" required placeholder="Digite a mensagem..."></textarea></div>
        <button type="submit" class="btn-primary"><i class="fab fa-discord"></i> Enviar</button>
      </form>
    </div>
    <div class="card">
      <h3><i class="fas fa-cog"></i> Configuração</h3>
      <p style="font-size:13px;color:#666;">Configure no arquivo <code>.env</code>:</p>
      <div style="background:#f5f5f5;padding:15px;border-radius:6px;font-family:monospace;font-size:13px;margin:10px 0;">
        DISCORD_WEBHOOK_URL=<%= webhookUrl ? webhookUrl : 'sua_webhook_url_aqui' %>
      </div>
      <p style="font-size:13px;color:#666;">Como criar um Webhook:</p>
      <ol style="font-size:13px;line-height:1.8;margin:5px 0 0 15px;padding:0;">
        <li>Abra seu servidor Discord</li>
        <li>Vá em <b>Configurações</b> > <b>Integrações</b> > <b>Webhooks</b></li>
        <li>Clique em <b>Novo Webhook</b></li>
        <li>Copie a URL e cole no <code>.env</code></li>
      </ol>
    </div>
  </div>
</div>
<%- include('../../partials/admin-footer') %>
