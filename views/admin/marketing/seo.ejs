<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/seo' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-search"></i> SEO & Indexação</h1>
    <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
  </div>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="card">
      <h3><i class="fas fa-sitemap"></i> Sitemap</h3>
      <p style="font-size:13px;color:#666;margin-bottom:8px;">URL: <a href="<%= baseUrl %>/sitemap.xml" target="_blank" style="color:#1565c0;"><%= baseUrl %>/sitemap.xml</a></p>
      <div style="background:#f5f5f5;padding:12px;border-radius:6px;font-family:monospace;font-size:11px;max-height:300px;overflow:auto;white-space:pre-wrap;border:1px solid #e0e0e0;"><%= sitemapContent %></div>
    </div>
    <div>
      <div class="form-card" style="margin-bottom:20px;">
        <h3><i class="fas fa-globe"></i> Ping Search Engines</h3>
        <p style="font-size:13px;color:#666;">Notifica Google e Bing sobre atualizações no sitemap</p>
        <form method="POST" action="/admin/marketing/seo/ping">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-primary"><i class="fas fa-bell"></i> Ping Google & Bing</button>
        </form>
      </div>
      <div class="card">
        <h3><i class="fab fa-google"></i> Google Indexing API</h3>
        <p style="font-size:13px;color:#666;">Chave: <strong><%= googleKey || 'Não configurada' %></strong></p>
        <p style="font-size:13px;color:#666;">Configure <code>GOOGLE_INDEXING_KEY</code> no <code>.env</code> para usar a Indexing API e submeter URLs diretamente ao Google.</p>
      </div>
      <div class="card" style="margin-top:15px;">
        <h3><i class="fas fa-file-export"></i> SEO Check</h3>
        <ul style="font-size:13px;line-height:2;margin:0;padding-left:16px;">
          <li>✅ Sitemap gerado com <%= sitemapContent.split('<url>').length - 1 %> URLs</li>
          <li><%= googleKey ? '✅' : '❌' %> Google Indexing API</li>
          <li>📊 Robots.txt: <a href="<%= baseUrl %>/robots.txt" target="_blank" style="color:#1565c0;">verificar</a></li>
        </ul>
      </div>
    </div>
  </div>
</div>
<style>
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
</style>
<%- include('../../partials/admin-footer') %>
