<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-bullhorn"></i> Marketing Central</h1>
    <span style="font-size:13px;color:#666;">Sistema completo de divulgação</span>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Stats Row -->
  <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:24px;">
    <div class="mstat-card"><div class="mstat-icon" style="background:#e8f5e9;color:#2e7d32;"><i class="fab fa-whatsapp"></i></div><div class="mstat-value"><%= stats.waToday %></div><div class="mstat-label">WhatsApp Hoje</div></div>
    <div class="mstat-card"><div class="mstat-icon" style="background:#e3f2fd;color:#1565c0;"><i class="fas fa-envelope"></i></div><div class="mstat-value"><%= stats.totalSent %></div><div class="mstat-label">Total Enviado</div></div>
    <div class="mstat-card"><div class="mstat-icon" style="background:#fff3e0;color:#e65100;"><i class="fas fa-rocket"></i></div><div class="mstat-value"><%= stats.totalCampaigns %></div><div class="mstat-label">Campanhas</div></div>
    <div class="mstat-card"><div class="mstat-icon" style="background:#f3e5f5;color:#6a1b9a;"><i class="fas fa-file-alt"></i></div><div class="mstat-value"><%= stats.totalTemplates %></div><div class="mstat-label">Modelos</div></div>
    <div class="mstat-card"><div class="mstat-icon" style="background:#e8eaf6;color:#283593;"><i class="fas fa-list"></i></div><div class="mstat-value"><%= stats.totalLists %></div><div class="mstat-label">Listas</div></div>
    <div class="mstat-card"><div class="mstat-icon" style="background:#fce4ec;color:#c62828;"><i class="fas fa-robot"></i></div><div class="mstat-value"><%= stats.totalAutoReplies %></div><div class="mstat-label">Auto-Respostas</div></div>
  </div>

  <!-- Platform Cards -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:15px;margin-bottom:24px;">
    <a href="/admin/marketing/whatsapp" class="platform-card" style="border-left:4px solid #25D366;">
      <div class="plat-icon" style="color:#25D366;"><i class="fab fa-whatsapp"></i></div>
      <div class="plat-name">WhatsApp</div>
      <div class="plat-status"><span class="badge badge-<%= waReady ? 'success' : 'muted' %>"><%= waReady ? 'Conectado' : 'Desconectado' %></span></div>
    </a>
    <a href="/admin/marketing/telegram" class="platform-card" style="border-left:4px solid #0088cc;">
      <div class="plat-icon" style="color:#0088cc;"><i class="fab fa-telegram-plane"></i></div>
      <div class="plat-name">Telegram</div>
      <div class="plat-status"><span class="badge badge-<%= telegramConfigured ? 'success' : 'muted' %>"><%= telegramConfigured ? 'Configurado' : 'Não configurado' %></span></div>
    </a>
    <a href="/admin/marketing/discord" class="platform-card" style="border-left:4px solid #5865F2;">
      <div class="plat-icon" style="color:#5865F2;"><i class="fab fa-discord"></i></div>
      <div class="plat-name">Discord</div>
      <div class="plat-status"><span class="badge badge-<%= discordConfigured ? 'success' : 'muted' %>"><%= discordConfigured ? 'Configurado' : 'Não configurado' %></span></div>
    </a>
    <a href="/admin/marketing/email" class="platform-card" style="border-left:4px solid #EA4335;">
      <div class="plat-icon" style="color:#EA4335;"><i class="fas fa-envelope"></i></div>
      <div class="plat-name">Email</div>
      <div class="plat-status"><span class="badge badge-<%= emailConfigured ? 'success' : 'muted' %>"><%= emailConfigured ? 'Configurado' : 'Não configurado' %></span></div>
    </a>
    <a href="/admin/marketing/seo" class="platform-card" style="border-left:4px solid #FF6F00;">
      <div class="plat-icon" style="color:#FF6F00;"><i class="fas fa-search"></i></div>
      <div class="plat-name">SEO</div>
      <div class="plat-status"><span class="badge badge-primary">Ativo</span></div>
    </a>
    <a href="/admin/marketing/campaigns" class="platform-card" style="border-left:4px solid #9C27B0;">
      <div class="plat-icon" style="color:#9C27B0;"><i class="fas fa-rocket"></i></div>
      <div class="plat-name">Campanhas</div>
      <div class="plat-status"><span class="badge badge-primary"><%= stats.totalCampaigns %> realizadas</span></div>
    </a>
    <a href="/admin/marketing/templates" class="platform-card" style="border-left:4px solid #607D8B;">
      <div class="plat-icon" style="color:#607D8B;"><i class="fas fa-file-alt"></i></div>
      <div class="plat-name">Modelos</div>
      <div class="plat-status"><span class="badge badge-primary"><%= stats.totalTemplates %> salvos</span></div>
    </a>
    <a href="/admin/marketing/social" class="platform-card" style="border-left:4px solid #E91E63;">
      <div class="plat-icon" style="color:#E91E63;"><i class="fas fa-share-alt"></i></div>
      <div class="plat-name">Redes Sociais</div>
      <div class="plat-status"><span class="badge badge-primary">Links</span></div>
    </a>
    <a href="/admin/marketing/qrcode" class="platform-card" style="border-left:4px solid #00BCD4;">
      <div class="plat-icon" style="color:#00BCD4;"><i class="fas fa-qrcode"></i></div>
      <div class="plat-name">QR Code</div>
      <div class="plat-status"><span class="badge badge-primary">Gerar</span></div>
    </a>
    <a href="/admin/marketing/autopromo" class="platform-card" style="border-left:4px solid #FF5722;">
      <div class="plat-icon" style="color:#FF5722;"><i class="fas fa-bolt"></i></div>
      <div class="plat-name">Auto-Promo</div>
      <div class="plat-status"><span class="badge badge-primary">Produtos</span></div>
    </a>
    <a href="/admin/marketing/lists" class="platform-card" style="border-left:4px solid #795548;">
      <div class="plat-icon" style="color:#795548;"><i class="fas fa-list"></i></div>
      <div class="plat-name">Listas</div>
      <div class="plat-status"><span class="badge badge-primary">Segmentação</span></div>
    </a>
    <a href="/admin/marketing/autoreply" class="platform-card" style="border-left:4px solid #4CAF50;">
      <div class="plat-icon" style="color:#4CAF50;"><i class="fas fa-robot"></i></div>
      <div class="plat-name">Auto-Resposta</div>
      <div class="plat-status"><span class="badge badge-primary"><%= stats.totalAutoReplies %> regras</span></div>
    </a>
    <a href="/admin/marketing/coupons" class="platform-card" style="border-left:4px solid #FF9800;">
      <div class="plat-icon" style="color:#FF9800;"><i class="fas fa-ticket-alt"></i></div>
      <div class="plat-name">Cupons</div>
      <div class="plat-status"><span class="badge badge-primary">Distribuir</span></div>
    </a>
    <a href="/admin/marketing/reports" class="platform-card" style="border-left:4px solid #37474F;">
      <div class="plat-icon" style="color:#37474F;"><i class="fas fa-chart-bar"></i></div>
      <div class="plat-name">Relatórios</div>
      <div class="plat-status"><span class="badge badge-primary">Exportar</span></div>
    </a>
  </div>

  <!-- Quick Action + Recent Campaigns -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="card">
      <h3><i class="fas fa-bolt"></i> Ação Rápida</h3>
      <p style="font-size:13px;color:#666;margin-bottom:12px;">Disparo em todas as plataformas com 1 clique</p>
      <form method="POST" action="/admin/marketing/campaigns/disparar">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="platforms" value="whatsapp">
        <input type="hidden" name="platforms" value="telegram">
        <input type="hidden" name="platforms" value="discord">
        <textarea name="message" class="admin-input" rows="3" placeholder="Digite a mensagem para disparo rápido..." style="font-size:13px;"></textarea>
        <div style="display:flex;gap:8px;margin-top:8px;">
          <button type="submit" class="btn-primary" style="background:#FF6F00;border-color:#FF6F00;"><i class="fas fa-rocket"></i> Disparar Agora</button>
          <a href="/admin/marketing/campaigns" class="btn-secondary" style="padding:8px 16px;border:1px solid #ddd;border-radius:6px;text-decoration:none;font-size:13px;">Campanhas completas</a>
        </div>
      </form>
    </div>
    <div class="card">
      <h3><i class="fas fa-history"></i> Últimas Campanhas</h3>
      <% if (campaigns.length === 0) { %><p style="color:#999;font-size:13px;">Nenhuma campanha realizada ainda.</p><% } else { %>
      <table class="admin-table" style="font-size:13px;">
        <thead><tr><th>Nome</th><th>Plataformas</th><th>Enviadas</th><th>Data</th></tr></thead>
        <tbody><% campaigns.slice(0,5).forEach(function(c) { %>
          <tr>
            <td><a href="/admin/marketing/campaigns/<%= c.id %>" style="color:#1565c0;text-decoration:none;"><%= c.name || 'Campanha #' + c.id %></a></td>
            <td style="font-size:11px;"><%= (c.platforms||'').replace(/,/g,', ') %></td>
            <td><%= c.total_sent %>/<%= c.total_sent + c.total_failed %></td>
            <td style="font-size:11px;color:#999;"><%= (c.created_at||'').slice(0,16).replace('T',' ') %></td>
          </tr>
        <% }) %></tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<style>
.mstat-card { background:var(--card-bg,#fff); border:1px solid var(--border,#ddd); border-radius:10px; padding:16px; display:flex; flex-direction:column; align-items:center; text-align:center; }
.mstat-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px; margin-bottom:8px; }
.mstat-value { font-size:22px; font-weight:700; line-height:1.2; }
.mstat-label { font-size:11px; color:#666; margin-top:2px; }
.platform-card { background:var(--card-bg,#fff); border:1px solid var(--border,#ddd); border-radius:10px; padding:18px; text-decoration:none; color:inherit; display:flex; flex-direction:column; gap:4px; transition:all .2s; }
.platform-card:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(0,0,0,.1); }
.plat-icon { font-size:28px; }
.plat-name { font-size:15px; font-weight:600; }
.plat-status { font-size:12px; }
.badge-primary { background:#e3f2fd; color:#1565c0; padding:2px 8px; border-radius:10px; font-size:11px; }
.badge-muted { background:#f5f5f5; color:#999; padding:2px 8px; border-radius:10px; font-size:11px; }
.badge-success { background:#e8f5e9; color:#2e7d32; padding:2px 8px; border-radius:10px; font-size:11px; }
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
</style>
<%- include('../../partials/admin-footer') %>
