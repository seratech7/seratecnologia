<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/whatsapp' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fab fa-whatsapp"></i> WhatsApp Marketing</h1>
    <div style="display:flex;gap:8px;">
      <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
      <a href="/admin/marketing/templates?platform=whatsapp" class="btn-secondary"><i class="fas fa-file-alt"></i> Modelos</a>
    </div>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Status + Conexão -->
  <div class="card" style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:15px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:32px;"><%= waReady ? '🟢' : (waQr ? '🟡' : '🔴') %></span>
        <div><strong style="font-size:16px;"><%= waReady ? 'Conectado' : (waQr ? 'Aguardando QR' : 'Desconectado') %></strong>
        <span style="font-size:12px;color:#666;display:block;"><%= waReady ? 'WhatsApp ativo e pronto para enviar' : (waQr ? 'Escaneie o QR abaixo para conectar' : 'Clique em Conectar para iniciar') %></span></div>
      </div>
      <div style="display:flex;gap:8px;">
        <% if (!waReady) { %><form method="POST" action="/admin/marketing/whatsapp/connect" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn-primary"><i class="fas fa-plug"></i> Conectar</button></form><% } %>
        <% if (waReady) { %><form method="POST" action="/admin/marketing/whatsapp/disconnect" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn-danger" onclick="return confirm('Desconectar WhatsApp?')"><i class="fas fa-power-off"></i> Desconectar</button></form><% } %>
      </div>
    </div>
    <% if (waQr && !waReady) { %>
      <div style="margin-top:15px;text-align:center;padding:15px;background:#fafafa;border-radius:8px;">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=280x280&data=<%= encodeURIComponent(waQr) %>" style="border:3px solid #25D366;border-radius:12px;max-width:250px;">
        <p style="font-size:13px;color:#666;margin-top:8px;">WhatsApp > Menu > Dispositivos Conectados</p>
      </div>
    <% } %>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;">
    <div class="wa-stat"><div class="wa-stat-value"><%= stats.contacts %></div><div class="wa-stat-label">Contatos</div></div>
    <div class="wa-stat"><div class="wa-stat-value"><%= stats.messages %></div><div class="wa-stat-label">Total Enviadas</div></div>
    <div class="wa-stat"><div class="wa-stat-value"><%= stats.today %></div><div class="wa-stat-label">Enviadas Hoje</div></div>
    <div class="wa-stat"><div class="wa-stat-value"><%= contacts.length %></div><div class="wa-stat-label">Na Base</div></div>
  </div>

  <!-- Conteúdo principal -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <!-- Envio Rápido -->
    <div class="form-card">
      <h3><i class="fas fa-paper-plane"></i> Envio Rápido</h3>
      <form method="POST" action="/admin/marketing/whatsapp/send">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group"><label>Número <small>(código do país + DDD + número)</small></label><input type="text" name="phone" class="admin-input" required placeholder="5511999999999"></div>
        <div class="form-group">
          <label>Mensagem</label>
          <textarea name="message" class="admin-input" rows="4" required placeholder="Digite a mensagem..."></textarea>
        </div>
        <button type="submit" class="btn-primary" <%= waReady ? '' : 'disabled' %>><i class="fas fa-send"></i> Enviar</button>
        <% if (!waReady) { %><p style="font-size:12px;color:#c62828;margin-top:5px;">Conecte o WhatsApp primeiro</p><% } %>
      </form>
    </div>

    <!-- Contatos e Envio em Massa -->
    <div>
      <div class="form-card" style="margin-bottom:15px;">
        <h3><i class="fas fa-users"></i> Contatos</h3>
        <form method="POST" action="/admin/marketing/whatsapp/contacts/add" style="display:flex;gap:5px;margin-bottom:8px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="text" name="name" placeholder="Nome" class="admin-input" style="flex:1;font-size:13px;">
          <input type="text" name="phone" placeholder="Telefone" class="admin-input" style="flex:1;font-size:13px;" required>
          <button type="submit" class="btn-primary" style="padding:8px 14px;">Adicionar</button>
        </form>
        <details style="font-size:13px;">
          <summary style="cursor:pointer;color:#666;">Importar CSV</summary>
          <form method="POST" action="/admin/marketing/whatsapp/contacts/import" style="margin-top:8px;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <textarea name="csv" class="admin-input" rows="2" placeholder="5511999999991,João&#10;5511999999992,Maria" style="font-size:12px;"></textarea>
            <button type="submit" class="btn-secondary" style="font-size:12px;padding:4px 12px;">Importar</button>
          </form>
        </details>
      </div>
      <div class="form-card">
        <h3><i class="fas fa-bullhorn"></i> Envio em Massa</h3>
        <form method="POST" action="/admin/marketing/whatsapp/send-all">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <textarea name="message" class="admin-input" rows="2" placeholder="Mensagem para todos os contatos..." style="font-size:13px;"></textarea>
          <button type="submit" class="btn-secondary" style="margin-top:5px;font-size:12px;" <%= waReady ? '' : 'disabled' %>>Enviar para <%= contacts.length %> contatos</button>
        </form>
        <% if (contacts.length > 0) { %>
        <div style="margin-top:10px;max-height:150px;overflow-y:auto;font-size:12px;border-top:1px solid #eee;padding-top:8px;">
          <% contacts.slice(0,15).forEach(function(c) { %>
            <div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid #f5f5f5;">
              <span><%= c.name || '—' %> <small style="color:#999;"><%= c.phone %></small></span>
              <form method="POST" action="/admin/marketing/whatsapp/contacts/delete/<%= c.id %>" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" style="background:none;border:none;color:#c62828;cursor:pointer;font-size:12px;" title="Remover">✕</button></form>
            </div>
          <% }) %>
          <% if (contacts.length > 15) { %><p style="color:#999;text-align:center;font-size:11px;padding:4px;">+ <%= contacts.length - 15 %> contatos</p><% } %>
        </div>
        <% } else { %><p style="font-size:12px;color:#999;margin-top:8px;">Nenhum contato cadastrado</p><% } %>
      </div>
    </div>
  </div>

  <!-- Modelos -->
  <% if (templates.length > 0) { %>
  <div class="card" style="margin-bottom:20px;">
    <h3><i class="fas fa-file-alt"></i> Modelos de Mensagem</h3>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;">
      <% templates.forEach(function(t) { %>
        <button type="button" class="template-chip" onclick="document.querySelector('[name=message]').value='<%= t.content.replace(/'/g,"\\'").replace(/\n/g,'\\n') %>';this.style.borderColor='#25D366'"><%= t.name %></button>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Últimas Mensagens -->
  <div class="card">
    <h3><i class="fas fa-history"></i> Últimas Mensagens</h3>
    <% if (recent.length === 0) { %><p style="color:#999;font-size:13px;">Nenhuma mensagem enviada.</p><% } else { %>
    <div style="overflow-x:auto;">
    <table class="admin-table">
      <thead><tr><th>Telefone</th><th>Mensagem</th><th>Status</th><th>Data</th></tr></thead>
      <tbody><% recent.forEach(function(m) { %>
        <tr><td><%= m.phone %></td><td style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:13px;"><%= m.message %></td><td><span class="badge badge-<%= m.status === 'sent' ? 'success' : 'danger' %>"><%= m.status %></span></td><td style="font-size:12px;color:#999;"><%= (m.sent_at||'').slice(0,16).replace('T',' ') %></td></tr>
      <% }) %></tbody>
    </table>
    </div>
    <% } %>
  </div>
</div>

<style>
.wa-stat { background:var(--card-bg,#fff); border:1px solid var(--border,#ddd); border-radius:10px; padding:16px; text-align:center; }
.wa-stat-value { font-size:26px; font-weight:700; color:#25D366; }
.wa-stat-label { font-size:11px; color:#666; margin-top:2px; }
.badge-success { background:#e8f5e9; color:#2e7d32; padding:2px 8px; border-radius:10px; font-size:11px; }
.badge-danger { background:#ffebee; color:#c62828; padding:2px 8px; border-radius:10px; font-size:11px; }
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
.template-chip { background:#f0fdf4; border:1px solid #bbf7d0; border-radius:16px; padding:4px 14px; font-size:12px; color:#166534; cursor:pointer; }
.template-chip:hover { background:#dcfce7; }
</style>
<%- include('../../partials/admin-footer') %>
