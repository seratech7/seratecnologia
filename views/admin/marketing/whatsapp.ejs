<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/whatsapp' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fab fa-whatsapp"></i> WhatsApp Marketing</h1>
    <a href="/admin/marketing" class="btn-secondary" style="float:right;"><i class="fas fa-arrow-left"></i> Voltar</a>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Conexão -->
  <div class="card" style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:15px;">
      <div><strong>Status:</strong> <% if (waReady) { %><span style="color:#25D366;font-size:18px;">✅ Conectado</span><% } else if (waQr) { %><span style="color:#FFA500;font-size:18px;">⏳ QR gerado</span><% } else { %><span style="color:#999;font-size:18px;">❌ Desconectado</span><% } %></div>
      <div style="display:flex;gap:8px;">
        <% if (!waReady) { %><form method="POST" action="/admin/marketing/whatsapp/connect" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn-primary"><i class="fas fa-plug"></i> Conectar</button></form><% } %>
        <% if (waReady) { %><form method="POST" action="/admin/marketing/whatsapp/disconnect" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn-danger" onclick="return confirm('Desconectar?')"><i class="fas fa-power-off"></i> Desconectar</button></form><% } %>
      </div>
    </div>
    <% if (waQr && !waReady) { %>
      <div style="margin-top:15px;text-align:center;">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=280x280&data=<%= encodeURIComponent(waQr) %>" style="border:2px solid #25D366;border-radius:8px;max-width:250px;">
        <p style="font-size:13px;color:#666;">WhatsApp > Menu > WhatsApp Web (ou Linked Devices)</p>
      </div>
    <% } %>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:20px;">
    <div class="stat-card"><div class="stat-value"><%= stats.contacts %></div><div class="stat-label">Contatos</div></div>
    <div class="stat-card"><div class="stat-value"><%= stats.messages %></div><div class="stat-label">Enviadas</div></div>
    <div class="stat-card"><div class="stat-value"><%= stats.today %></div><div class="stat-label">Hoje</div></div>
  </div>

  <!-- Envio + Contatos lado a lado -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div class="form-card">
      <h3><i class="fas fa-paper-plane"></i> Envio Rápido</h3>
      <form method="POST" action="/admin/marketing/whatsapp/send">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group"><label>Número (5511999999999)</label><input type="text" name="phone" class="admin-input" required placeholder="5521999999999"></div>
        <div class="form-group"><label>Mensagem</label><textarea name="message" class="admin-input" rows="4" required placeholder="Digite a mensagem..."></textarea></div>
        <button type="submit" class="btn-primary" <%= waReady ? '' : 'disabled' %>><i class="fas fa-send"></i> Enviar</button>
      </form>
    </div>

    <div class="form-card">
      <h3><i class="fas fa-address-book"></i> Contatos</h3>
      <form method="POST" action="/admin/marketing/whatsapp/contacts/add" style="display:flex;gap:5px;margin-bottom:10px;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="text" name="name" placeholder="Nome" class="admin-input" style="flex:1;">
        <input type="text" name="phone" placeholder="Telefone" class="admin-input" style="flex:1;" required>
        <button type="submit" class="btn-primary" style="padding:8px 12px;">+</button>
      </form>
      <form method="POST" action="/admin/marketing/whatsapp/contacts/import" style="margin-bottom:10px;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <textarea name="csv" class="admin-input" rows="2" placeholder="5511999999991,João" style="font-size:12px;"></textarea>
        <button type="submit" class="btn-secondary" style="font-size:12px;padding:4px 10px;">Importar CSV</button>
      </form>
      <form method="POST" action="/admin/marketing/whatsapp/send-all">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <textarea name="message" class="admin-input" rows="2" placeholder="Mensagem para todos os contatos..." style="font-size:12px;"></textarea>
        <button type="submit" class="btn-secondary" style="font-size:12px;padding:4px 10px;" <%= waReady ? '' : 'disabled' %>>Enviar para <%= contacts.length %> contatos</button>
      </form>
      <% if (contacts.length > 0) { %>
      <div style="margin-top:8px;max-height:150px;overflow-y:auto;font-size:12px;">
        <% contacts.slice(0,20).forEach(function(c) { %>
          <div style="display:flex;justify-content:space-between;padding:2px 0;border-bottom:1px solid #eee;">
            <span><%= c.name || '—' %> <small style="color:#999;"><%= c.phone %></small></span>
            <form method="POST" action="/admin/marketing/whatsapp/contacts/delete/<%= c.id %>" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" style="background:none;border:none;color:#c62828;cursor:pointer;font-size:12px;">✕</button></form>
          </div>
        <% }) %>
        <% if (contacts.length > 20) { %><p style="color:#999;text-align:center;">+ <%= contacts.length - 20 %> mais...</p><% } %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Últimas Mensagens -->
  <div class="card">
    <h3><i class="fas fa-history"></i> Últimas Mensagens</h3>
    <% if (recent.length === 0) { %><p style="color:#999;">Nenhuma mensagem enviada.</p><% } else { %>
    <table class="admin-table">
      <thead><tr><th>Telefone</th><th>Mensagem</th><th>Status</th><th>Data</th></tr></thead>
      <tbody><% recent.forEach(function(m) { %>
        <tr><td><%= m.phone %></td><td style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= m.message %></td><td><span class="badge badge-<%= m.status === 'sent' ? 'success' : 'danger' %>"><%= m.status %></span></td><td style="font-size:12px;"><%= m.sent_at %></td></tr>
      <% }) %></tbody>
    </table>
    <% } %>
  </div>
</div>
<style>
.stat-card { background:var(--card-bg,#fff); border:1px solid var(--border,#ddd); border-radius:8px; padding:15px; text-align:center; }
.stat-value { font-size:24px; font-weight:700; color:#25D366; }
.stat-label { font-size:12px; color:#666; }
.badge-success { background:#e8f5e9; color:#2e7d32; padding:2px 8px; border-radius:10px; font-size:11px; }
.badge-danger { background:#ffebee; color:#c62828; padding:2px 8px; border-radius:10px; font-size:11px; }
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; }
.btn-secondary:hover { background:#e0e0e0; }
</style>
<%- include('../../partials/admin-footer') %>
