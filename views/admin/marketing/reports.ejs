<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/reports' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-chart-bar"></i> Relatórios de Marketing</h1>
    <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
  </div>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Resumo -->
  <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:24px;">
    <div class="rstat"><span class="rnum"><%= stats.totalCampaigns %></span><span>Campanhas</span></div>
    <div class="rstat"><span class="rnum"><%= stats.totalSent %></span><span>Mensagens Enviadas</span></div>
    <div class="rstat"><span class="rnum"><%= stats.totalWaSent + stats.waToday %></span><span>WhatsApp Total</span></div>
    <div class="rstat"><span class="rnum"><%= stats.totalLists %></span><span>Listas</span></div>
    <div class="rstat"><span class="rnum"><%= stats.totalAutoReplies %></span><span>Auto-Respostas</span></div>
  </div>

  <!-- Export -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">
    <div class="card">
      <h3><i class="fas fa-download"></i> Exportar Dados</h3>
      <p style="font-size:13px;color:#666;">Baixe relatórios em CSV para análise</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <a href="/admin/marketing/reports/export/whatsapp" class="btn-secondary"><i class="fab fa-whatsapp"></i> WhatsApp</a>
        <a href="/admin/marketing/reports/export/campaigns" class="btn-secondary"><i class="fas fa-rocket"></i> Campanhas</a>
        <a href="/admin/marketing/reports/export/contacts" class="btn-secondary"><i class="fas fa-address-book"></i> Contatos</a>
      </div>
    </div>
    <div class="card">
      <h3><i class="fas fa-clock"></i> Agendamentos Pendentes</h3>
      <% if (schedules.length === 0) { %><p style="color:#999;font-size:13px;">Nenhum agendamento pendente.</p><% } else { %>
        <% schedules.forEach(function(s) { %>
          <div style="font-size:13px;padding:4px 0;border-bottom:1px solid #f5f5f5;"><strong><%= s.title %></strong> — <%= s.platform %> — <%= (s.scheduled_for||'').slice(0,16).replace('T',' ') %></div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Últimas Campanhas -->
  <div class="card" style="margin-bottom:20px;">
    <h3><i class="fas fa-history"></i> Últimas Campanhas</h3>
    <% if (campaigns.length === 0) { %><p style="color:#999;font-size:13px;">Nenhuma campanha.</p><% } else { %>
    <table class="admin-table">
      <thead><tr><th>Nome</th><th>Plataformas</th><th>Enviadas</th><th>Falhas</th><th>Data</th></tr></thead>
      <tbody><% campaigns.forEach(function(c) { %>
        <tr><td><%= c.name || '—' %></td><td><%= (c.platforms||'').replace(/,/,', ') %></td><td><%= c.total_sent %></td><td><%= c.total_failed %></td><td style="font-size:12px;"><%= (c.created_at||'').slice(0,16).replace('T',' ') %></td></tr>
      <% }) %></tbody>
    </table>
    <% } %>
  </div>

  <!-- Últimas Mensagens WhatsApp -->
  <div class="card">
    <h3><i class="fab fa-whatsapp"></i> Últimas Mensagens WhatsApp</h3>
    <% if (recentMsgs.length === 0) { %><p style="color:#999;font-size:13px;">Nenhuma mensagem.</p><% } else { %>
    <table class="admin-table">
      <thead><tr><th>Telefone</th><th>Mensagem</th><th>Status</th><th>Data</th></tr></thead>
      <tbody><% recentMsgs.forEach(function(m) { %>
        <tr><td><%= m.phone %></td><td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= m.message %></td><td><span class="badge badge-<%= m.status === 'sent' ? 'success' : 'danger' %>"><%= m.status %></span></td><td style="font-size:12px;"><%= (m.sent_at||'').slice(0,16).replace('T',' ') %></td></tr>
      <% }) %></tbody>
    </table>
    <% } %>
  </div>
</div>
<style>
.rstat { background:var(--card-bg,#fff); border:1px solid var(--border,#ddd); border-radius:8px; padding:14px; text-align:center; display:flex; flex-direction:column; gap:2px; font-size:12px; color:#666; }
.rnum { font-size:24px; font-weight:700; color:#1565c0; }
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
.badge-success { background:#e8f5e9; color:#2e7d32; padding:2px 8px; border-radius:10px; font-size:11px; }
.badge-danger { background:#ffebee; color:#c62828; padding:2px 8px; border-radius:10px; font-size:11px; }
</style>
<%- include('../../partials/admin-footer') %>
