<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/coupons' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-ticket-alt"></i> Distribuir Cupons</h1>
    <p style="font-size:13px;color:#666;margin:0;">Envie cupons de desconto para seus contatos</p>
    <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
  </div>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="form-card">
    <form method="POST" action="/admin/marketing/coupons/send">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:15px;">
        <div class="form-group">
          <label>Cupom</label>
          <select name="couponId" class="admin-input" required>
            <option value="">-- Selecione --</option>
            <% coupons.forEach(function(c) { %>
              <option value="<%= c.id %>"><%= c.code %> - <%= c.discount_value %><%= c.type === 'percentage' ? '%' : '' %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Enviar para</label>
          <select name="target" class="admin-input" required>
            <option value="whatsapp">WhatsApp (contatos)</option>
            <option value="whatsapp_list">WhatsApp (lista específica)</option>
            <option value="telegram">Telegram</option>
            <option value="discord">Discord</option>
          </select>
        </div>
        <div class="form-group" id="listGroup" style="display:none;">
          <label>Lista</label>
          <select name="listId" class="admin-input">
            <option value="">-- Selecione --</option>
            <% lists.forEach(function(l) { %>
              <option value="<%= l.id %>"><%= l.name %> (<%= l.member_count %> membros)</option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Mensagem <small>(use {code} para o código do cupom, {valor} para o valor)</small></label>
        <textarea name="message" class="admin-input" rows="3" placeholder="Cupom exclusivo: {code} - {valor} de desconto! Acesse: <%= baseUrl %>"><%= 'Cupom exclusivo: {code}\n\nAcesse: ' + baseUrl %></textarea>
      </div>
      <button type="submit" class="btn-primary"><i class="fas fa-paper-plane"></i> Distribuir Cupom</button>
    </form>
  </div>
</div>
<script>
document.querySelector('[name=target]').addEventListener('change', function() {
  document.getElementById('listGroup').style.display = this.value === 'whatsapp_list' ? 'block' : 'none';
});
</script>
<style>
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
</style>
<%- include('../../partials/admin-footer') %>
