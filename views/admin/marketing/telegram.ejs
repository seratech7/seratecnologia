<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/telegram' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fab fa-telegram-plane"></i> Telegram</h1>
    <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
  </div>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Status -->
  <div class="card" style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;gap:10px;">
      <span style="font-size:28px;"><%= botToken ? '🟢' : '🔴' %></span>
      <div><strong style="font-size:16px;"><%= botToken ? 'Telegram Configurado' : 'Telegram Não Configurado' %></strong>
      <span style="font-size:12px;color:#666;display:block;"><%= botToken ? 'Bot Token: ' + botToken.slice(0,8) + '... | Chat ID: ' + chatId : 'Configure TELEGRAM_BOT_TOKEN e TELEGRAM_CHAT_ID no .env' %></span></div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="form-card">
      <h3><i class="fas fa-paper-plane"></i> Enviar Mensagem</h3>
      <% if (templates.length > 0) { %>
      <div style="margin-bottom:8px;display:flex;flex-wrap:wrap;gap:4px;">
        <% templates.forEach(function(t) { %>
          <button type="button" class="tchip" onclick="document.querySelector('[name=message]').value='<%= t.content.replace(/'/g,"\\'").replace(/\n/g,'\\n') %>'"><%= t.name %></button>
        <% }) %>
      </div>
      <% } %>
      <form method="POST" action="/admin/marketing/telegram/send">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group"><label>Mensagem <small>(HTML: &lt;b&gt;, &lt;i&gt;, &lt;a&gt;)</small></label><textarea name="message" class="admin-input" rows="6" required placeholder="Digite a mensagem..."></textarea></div>
        <button type="submit" class="btn-primary" <%= botToken && chatId ? '' : 'disabled' %>><i class="fab fa-telegram-plane"></i> Enviar</button>
      </form>
    </div>
    <div>
      <div class="card" style="margin-bottom:15px;">
        <h3><i class="fas fa-cog"></i> Configuração</h3>
        <div style="background:#f5f5f5;padding:12px;border-radius:6px;font-family:monospace;font-size:12px;margin:10px 0;word-break:break-all;">
          TELEGRAM_BOT_TOKEN=<%= botToken || 'seu_token' %><br>
          TELEGRAM_CHAT_ID=<%= chatId || 'seu_chat_id' %>
        </div>
        <details style="font-size:13px;">
          <summary style="cursor:pointer;color:#666;">Como criar um bot</summary>
          <ol style="font-size:12px;line-height:1.8;margin:8px 0 0 16px;padding:0;">
            <li>Abra o Telegram e procure <b>@BotFather</b></li>
            <li>Envie <code>/newbot</code> e escolha um nome</li>
            <li>Copie o token e coloque no <code>.env</code></li>
            <li>Adicione o bot a um grupo e marque ele</li>
            <li>Acesse <code>https://api.telegram.org/botSEU_TOKEN/getUpdates</code> para ver o chat_id</li>
          </ol>
        </details>
      </div>
      <div class="card">
        <h3><i class="fas fa-plug"></i> Testar Conexão</h3>
        <p style="font-size:13px;color:#666;">Verifica se o token do bot é válido</p>
        <button type="button" class="btn-secondary" onclick="testTelegram()">Testar Bot</button>
        <div id="telegramTestResult" style="margin-top:8px;font-size:13px;"></div>
      </div>
    </div>
  </div>
</div>
<script>
async function testTelegram() {
  const el = document.getElementById('telegramTestResult');
  el.innerHTML = '<span style="color:#999;">Testando...</span>';
  try {
    const r = await fetch('/admin/marketing/telegram/test', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' } });
    const d = await r.json();
    el.innerHTML = d.ok ? '<span style="color:#2e7d32;">✅ Bot @' + d.bot + ' ativo</span>' : '<span style="color:#c62828;">❌ ' + (d.error||'Erro') + '</span>';
  } catch(e) { el.innerHTML = '<span style="color:#c62828;">Erro: ' + e.message + '</span>'; }
}
</script>
<style>
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
.tchip { background:#f0f9ff; border:1px solid #bae6fd; border-radius:14px; padding:3px 10px; font-size:11px; color:#0369a1; cursor:pointer; }
.tchip:hover { background:#e0f2fe; }
</style>
<%- include('../../partials/admin-footer') %>
