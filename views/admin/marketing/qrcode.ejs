<%- include('../../partials/admin-header', { title: title, currentPath: '/admin/marketing/qrcode' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-qrcode"></i> Gerador de QR Code</h1>
    <a href="/admin/marketing" class="btn-secondary"><i class="fas fa-arrow-left"></i> Painel</a>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:30px;">
    <div class="form-card">
      <h3><i class="fas fa-edit"></i> Conteúdo do QR</h3>
      <div class="form-group">
        <label>URL ou Texto</label>
        <input type="url" id="qrInput" class="admin-input" value="<%= baseUrl %>" placeholder="https://...">
      </div>
      <div class="form-group">
        <label>Tamanho</label>
        <select id="qrSize" class="admin-input">
          <option value="200">Pequeno (200x200)</option>
          <option value="280" selected>Médio (280x280)</option>
          <option value="400">Grande (400x400)</option>
          <option value="500">Extra (500x500)</option>
        </select>
      </div>
      <button type="button" class="btn-primary" onclick="gerarQR()"><i class="fas fa-sync"></i> Gerar QR Code</button>
      <a id="downloadLink" class="btn-secondary" style="display:none;margin-left:8px;" download="qrcode.png"><i class="fas fa-download"></i> Download PNG</a>
    </div>
    <div class="card" style="text-align:center;">
      <h3><i class="fas fa-image"></i> Preview</h3>
      <div id="qrContainer" style="margin:20px auto;min-height:280px;display:flex;align-items:center;justify-content:center;">
        <img id="qrImage" src="https://api.qrserver.com/v1/create-qr-code/?size=280x280&data=<%= encodeURIComponent(baseUrl) %>" style="border:2px solid #ddd;border-radius:8px;max-width:100%;">
      </div>
      <p style="font-size:12px;color:#666;">Use em materiais gráficos, cartões, banners e redes sociais</p>
    </div>
  </div>
</div>
<script>
function gerarQR() {
  const data = encodeURIComponent(document.getElementById('qrInput').value || '<%= baseUrl %>');
  const size = document.getElementById('qrSize').value;
  const src = 'https://api.qrserver.com/v1/create-qr-code/?size=' + size + 'x' + size + '&data=' + data;
  document.getElementById('qrImage').src = src;
  const dl = document.getElementById('downloadLink');
  dl.href = src;
  dl.style.display = 'inline-block';
}
document.getElementById('qrInput').addEventListener('input', gerarQR);
document.getElementById('qrSize').addEventListener('change', gerarQR);
</script>
<style>
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; border:1px solid #ddd; cursor:pointer; display:inline-block; }
.btn-secondary:hover { background:#e0e0e0; }
</style>
<%- include('../../partials/admin-footer') %>
