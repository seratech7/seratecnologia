<%- include('../partials/admin-header') %>

<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-microchip"></i> Dashboard SeraTecnologia</h1>
    <p>Bem-vindo, <%= session.adminName %>!</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon products-icon"><i class="fas fa-box"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.total %></span>
        <span class="stat-label">Total de Produtos</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon active-icon"><i class="fas fa-check-circle"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.active %></span>
        <span class="stat-label">Produtos Ativos</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
        <i class="fas fa-clock"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.pending %></span>
        <span class="stat-label">Pendentes</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon categories-icon"><i class="fas fa-store-alt"></i></div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.sellers %></span>
        <span class="stat-label">Vendedores</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #ffd700, #ffaa00);">
        <i class="fas fa-star"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.featured %></span>
        <span class="stat-label">Em Destaque</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #00c853, #00a844);">
        <i class="fas fa-shopping-bag"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.totalSales %></span>
        <span class="stat-label">Vendas Realizadas</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #9c27b0, #7b1fa2);">
        <i class="fas fa-dollar-sign"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(stats.revenue) %></span>
        <span class="stat-label">Receita Total</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #ff9800, #f57c00);">
        <i class="fas fa-clock"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.pendingSales %></span>
        <span class="stat-label">Vendas Pendentes</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #2196f3, #1565c0);">
        <i class="fas fa-eye"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.totalViews %></span>
        <span class="stat-label">Total de Visualizações</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #00bcd4, #00838f);">
        <i class="fas fa-chart-bar"></i>
      </div>
      <div class="stat-info">
        <span class="stat-number"><%= stats.todayViews %></span>
        <span class="stat-label">Views Hoje</span>
      </div>
    </div>
  </div>

  <% if (featuredProducts.length > 0) { %>
  <div class="admin-section">
    <div class="section-header">
      <h2><i class="fas fa-star" style="color:#ffd700;"></i> Produtos em Destaque</h2>
      <a href="/admin/products?filter=featured" class="btn-small">Gerenciar</a>
    </div>
    <div class="featured-carousel">
      <div class="products-grid featured-admin-grid">
        <% featuredProducts.forEach(p => { %>
          <a href="/admin/products/edit/<%= p.id %>" class="product-card featured-admin-card">
            <div class="product-image">
              <% if (p.image) { %><img src="<%= p.image %>" alt=""><% } else { %><div class="no-image"><i class="fas fa-image"></i></div><% } %>
              <span class="featured-badge"><i class="fas fa-star"></i> Destaque</span>
            </div>
            <div class="product-info">
              <h3 class="product-name"><%= p.name %></h3>
              <p class="product-price"><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(p.price) %></p>
              <div class="product-meta">
                <span><%= p.category_name || '-' %></span>
                <% if (p.seller_name) { %><span class="product-category"><%= p.seller_name %></span><% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <div class="admin-section">
    <div class="section-header">
      <h2><i class="fas fa-clock"></i> Produtos Recentes</h2>
      <a href="/admin/products" class="btn-small">Ver todos</a>
    </div>
    <div class="table-container">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Produto</th>
            <th>Preço</th>
            <th>Categoria</th>
            <th>Status</th>
            <th>Data</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentProducts.length === 0) { %>
            <tr><td colspan="6" class="empty-row">Nenhum produto cadastrado</td></tr>
          <% } else { %>
            <% recentProducts.forEach(p => { %>
              <tr>
                <td class="product-cell">
                  <div class="product-cell-info">
                    <% if (p.image) { %><img src="<%= p.image %>" alt="" class="thumb"><% } %>
                    <span><%= p.name %><% if (p.featured) { %> <span class="featured-tag"><i class="fas fa-star"></i></span><% } %></span>
                  </div>
                </td>
                <td><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(p.price) %></td>
                <td><%= p.category_name || '-' %></td>
                <td>
                  <% if (p.status === 'active') { %><span class="status-badge active">Ativo</span>
                  <% } else if (p.status === 'pending') { %><span class="status-badge" style="background:#fff3cd;color:#856404;">Pendente</span>
                  <% } else if (p.status === 'rejected') { %><span class="status-badge" style="background:#fdecea;color:#e74c3c;">Rejeitado</span>
                  <% } else { %><span class="status-badge inactive">Inativo</span><% } %>
                </td>
                <td><%= new Date(p.created_at).toLocaleDateString('pt-BR') %></td>
                <td>
                  <a href="/admin/products/edit/<%= p.id %>" class="btn-icon" title="Editar"><i class="fas fa-edit"></i></a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>
