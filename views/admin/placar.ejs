<%- include('../partials/admin-header') %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-ranking-star"></i> Placar de Metas</h1>
  </div>
  <% if (selectedGoal) { %>
    <div style="display:flex;gap:12px;align-items:center;margin-bottom:16px;flex-wrap:wrap;">
      <form method="GET" action="/admin/placar" style="display:flex;gap:8px;align-items:center;">
        <select name="goal_id" class="admin-select" style="width:auto;">
          <option value="">-- Meta ativa --</option>
          <% goals.forEach(function(g) { %>
            <option value="<%= g.id %>" <%= selectedGoal && selectedGoal.id == g.id ? 'selected' : '' %>><%= g.title %> (<%= g.start_date %> - <%= g.end_date %>)</option>
          <% }) %>
        </select>
        <button type="submit" class="btn-primary" style="padding:6px 12px;font-size:13px;">Filtrar</button>
      </form>
      <span style="font-size:13px;color:#666;">
        <i class="fas fa-bullseye"></i> <strong><%= selectedGoal.title %></strong>
        &middot; <%= selectedGoal.type === 'sales_count' ? selectedGoal.target_value + ' vendas' : 'R$ ' + parseFloat(selectedGoal.target_value).toFixed(2) %>
        <% if (selectedGoal.prize_description) { %> &middot; <i class="fas fa-gift" style="color:#e65100;"></i> <%= selectedGoal.prize_description %><% } %>
      </span>
    </div>
    <% if (leaderboard.length === 0) { %><p style="color:#999;">Nenhum vendedor encontrado</p><% } else { %>
    <div class="table-container">
      <table class="admin-table">
        <thead><tr><th>#</th><th>Vendedor</th><th>Progresso</th><th>%</th><th>Meta Batida</th><th>Prêmio</th></tr></thead>
        <tbody>
          <% leaderboard.forEach(function(s, idx) { %>
            <tr>
              <td style="font-size:18px;font-weight:700;text-align:center;">
                <% if (idx === 0) { %>🥇<% } else if (idx === 1) { %>🥈<% } else if (idx === 2) { %>🥉<% } else { %><%= idx + 1 %><% } %>
              </td>
              <td><img src="<%= s.avatar || '/images/default-avatar.png' %>" style="width:28px;height:28px;border-radius:50%;object-fit:cover;vertical-align:middle;margin-right:6px;"><%= s.seller_name %></td>
              <td style="min-width:200px;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <div style="flex:1;height:12px;background:#e0e0e0;border-radius:6px;overflow:hidden;">
                    <div style="height:100%;background:<%= s.achieved ? '#4caf50' : '#2196f3' %>;width:<%= Math.min(s.pct,100) %>%!important;border-radius:6px;transition:width .5s;"></div>
                  </div>
                  <span style="font-size:12px;white-space:nowrap;font-weight:600;"><%= s.progress %> / <%= s.target %></span>
                </div>
              </td>
              <td style="font-weight:700;font-size:16px;"><%= s.pct %>%</td>
              <td>
                <% if (s.achieved) { %>
                  <span style="color:#4caf50;font-weight:700;"><i class="fas fa-check-circle"></i> Sim</span>
                <% } else { %>
                  <span style="color:#999;">Não</span>
                <% } %>
              </td>
              <td>
                <% if (s.achieved) { %>
                  <form method="POST" action="/admin/metas/winner/<%= selectedGoal.id %>/<%= s.seller_id %>" style="display:inline;">
                    <input type="hidden" name="prize_given" value="<%= s.prize_given ? '0' : '1' %>">
                    <button type="submit" class="btn-small" style="<%= s.prize_given ? 'background:#e8f5e9;color:#2e7d32;' : 'background:#fff3e0;color:#e65100;' %>">
                      <i class="fas fa-gift"></i> <%= s.prize_given ? 'Prêmio Entregue' : 'Marcar Entregue' %>
                    </button>
                  </form>
                <% } else { %>
                  <span style="color:#ccc;">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  <% } else { %>
    <p style="color:#999;">Nenhuma meta ativa no momento. <a href="/admin/metas">Criar uma meta</a>.</p>
  <% } %>
</div>
<%- include('../partials/admin-footer') %>