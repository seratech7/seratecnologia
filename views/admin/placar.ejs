<%- include('../partials/admin-header') %>
<div class="admin-content">
  <div class="page-header">
    <div>
      <h1><i class="fas fa-ranking-star"></i> Placar de Metas</h1>
      <p>Acompanhe o progresso dos vendedores nas metas ativas</p>
    </div>
    <div>
      <form method="GET" action="/admin/placar" class="goal-filter">
        <select name="goal_id" class="admin-select">
          <option value="">-- Meta ativa --</option>
          <% goals.forEach(function(g) { %>
            <option value="<%= g.id %>" <%= selectedGoal && selectedGoal.id == g.id ? 'selected' : '' %>><%= g.title %> (<%= g.start_date %> - <%= g.end_date %>)</option>
          <% }) %>
        </select>
        <button type="submit" class="btn-primary"><i class="fas fa-filter"></i> Filtrar</button>
      </form>
    </div>
  </div>
  <% if (selectedGoal) { %>
    <div class="goal-info-bar">
      <i class="fas fa-bullseye"></i> <strong><%= selectedGoal.title %></strong>
      <span class="goal-info-sep">|</span>
      <%= selectedGoal.type === 'sales_count' ? selectedGoal.target_value + ' vendas' : 'R$ ' + parseFloat(selectedGoal.target_value).toFixed(2) %>
      <% if (selectedGoal.prize_description) { %>
        <span class="goal-info-sep">|</span>
        <i class="fas fa-gift" style="color:#e65100;"></i> <%= selectedGoal.prize_description %>
      <% } %>
    </div>
    <% if (leaderboard.length === 0) { %>
      <div class="empty-row">Nenhum vendedor encontrado para esta meta</div>
    <% } else { %>
    <div class="admin-section">
      <div class="section-header">
        <h2><i class="fas fa-trophy"></i> Classificação</h2>
        <span class="header-date"><%= leaderboard.length %> vendedor<%= leaderboard.length !== 1 ? 'es' : '' %></span>
      </div>
      <div class="table-container">
        <table class="admin-table">
          <thead><tr><th>#</th><th>Vendedor</th><th>Progresso</th><th>%</th><th>Meta Batida</th><th>Prêmio</th></tr></thead>
          <tbody>
            <% leaderboard.forEach(function(s, idx) { %>
              <tr class="<%= s.achieved ? 'row-achieved' : '' %>">
                <td class="rank-cell">
                  <% if (idx === 0) { %><span class="rank-badge rank-gold"><i class="fas fa-crown"></i></span>
                  <% } else if (idx === 1) { %><span class="rank-badge rank-silver">2</span>
                  <% } else if (idx === 2) { %><span class="rank-badge rank-bronze">3</span>
                  <% } else { %><%= idx + 1 %><% } %>
                </td>
                <td>
                  <div class="seller-cell">
                    <img src="<%= s.avatar || '/images/default-avatar.png' %>" class="seller-avatar-mini" onerror="this.style.display='none'">
                    <span><%= s.seller_name %></span>
                  </div>
                </td>
                <td>
                  <div class="progress-bar-container">
                    <div class="progress-bar">
                      <div class="progress-fill <%= s.achieved ? 'fill-success' : 'fill-primary' %>" style="width:<%= Math.min(s.pct,100) %>%"></div>
                    </div>
                    <span class="progress-label"><%= s.progress %> / <%= s.target %></span>
                  </div>
                </td>
                <td class="pct-cell"><%= s.pct %>%</td>
                <td>
                  <% if (s.achieved) { %>
                    <span class="status-badge active"><i class="fas fa-check-circle"></i> Sim</span>
                  <% } else { %>
                    <span class="status-badge inactive">Não</span>
                  <% } %>
                </td>
                <td>
                  <% if (s.achieved) { %>
                    <form method="POST" action="/admin/metas/winner/<%= selectedGoal.id %>/<%= s.seller_id %>" style="display:inline;">
                      <input type="hidden" name="prize_given" value="<%= s.prize_given ? '0' : '1' %>">
                      <button type="submit" class="btn-small <%= s.prize_given ? 'btn-given' : 'btn-pending' %>">
                        <i class="fas fa-gift"></i> <%= s.prize_given ? 'Prêmio Entregue' : 'Marcar Entregue' %>
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>
  <% } else { %>
    <div class="alert alert-info" style="margin-top:16px;">
      <i class="fas fa-info-circle"></i> Nenhuma meta ativa no momento. <a href="/admin/metas" style="font-weight:600;">Criar uma meta</a>.
    </div>
  <% } %>
</div>
<%- include('../partials/admin-footer') %>