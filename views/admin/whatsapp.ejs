<%- include('../partials/admin-header', { title: title, currentPath: '/admin/whatsapp' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fab fa-whatsapp"></i> WhatsApp Manager</h1>
    <p>Painel de disparo de mensagens automáticas</p>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <!-- Status Conexão -->
  <div class="card" style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:15px;">
      <div>
        <strong>Status:</strong>
        <% if (waReady) { %>
          <span style="color:#25D366;font-size:18px;">✅ Conectado</span>
        <% } else if (waQr) { %>
          <span style="color:#FFA500;font-size:18px;">⏳ QR Code gerado — escaneie com o celular</span>
        <% } else { %>
          <span style="color:#999;font-size:18px;">❌ Desconectado</span>
        <% } %>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <% if (!waReady) { %>
          <form method="POST" action="/admin/whatsapp/connect" style="display:inline;">
            <button type="submit" class="btn-primary"><i class="fas fa-plug"></i> Conectar WhatsApp</button>
          </form>
        <% } %>
        <% if (waReady) { %>
          <form method="POST" action="/admin/whatsapp/disconnect" style="display:inline;">
            <button type="submit" class="btn-danger" onclick="return confirm('Desconectar WhatsApp?')"><i class="fas fa-power-off"></i> Desconectar</button>
          </form>
        <% } %>
      </div>
    </div>
    <% if (waQr && !waReady) { %>
      <div style="margin-top:15px;text-align:center;">
        <p><strong>Escaneie o QR Code com seu celular:</strong></p>
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=<%= encodeURIComponent(waQr) %>"
             alt="QR Code" style="border:2px solid #25D366;border-radius:8px;max-width:250px;">
        <p style="font-size:13px;color:#666;margin-top:8px;">
          WhatsApp > Menu > WhatsApp Web (ou Linked Devices > Link a Device)
        </p>
      </div>
    <% } %>
  </div>

  <!-- Stats -->
  <div class="stats-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:15px;margin-bottom:20px;">
    <div class="stat-card"><div class="stat-value"><%= stats.contacts %></div><div class="stat-label">Contatos</div></div>
    <div class="stat-card"><div class="stat-value"><%= stats.messages %></div><div class="stat-label">Total Enviadas</div></div>
    <div class="stat-card"><div class="stat-value"><%= stats.today %></div><div class="stat-label">Enviadas Hoje</div></div>
  </div>

  <!-- Envio Rápido -->
  <div class="form-card" style="margin-bottom:20px;">
    <h3><i class="fas fa-paper-plane"></i> Envio Rápido</h3>
    <form method="POST" action="/admin/whatsapp/send">
      <div class="form-group">
        <label>Número (com DDD, ex: 5521999999999)</label>
        <input type="text" name="phone" class="admin-input" required placeholder="5521999999999">
      </div>
      <div class="form-group">
        <label>Mensagem</label>
        <textarea name="message" class="admin-input" rows="4" required placeholder="Digite a mensagem..."></textarea>
      </div>
      <button type="submit" class="btn-primary" <%= waReady ? '' : 'disabled' %>><i class="fas fa-send"></i> Enviar</button>
      <% if (!waReady) { %><span style="color:#999;margin-left:10px;">Conecte o WhatsApp primeiro</span><% } %>
    </form>
  </div>

  <!-- Últimas Mensagens -->
  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
      <h3 style="margin:0;"><i class="fas fa-history"></i> Últimas Mensagens</h3>
      <a href="/admin/whatsapp/history" class="btn-secondary">Ver Todas</a>
    </div>
    <% if (recent.length === 0) { %>
      <p style="color:#999;">Nenhuma mensagem enviada ainda.</p>
    <% } else { %>
      <table class="admin-table">
        <thead><tr><th>Telefone</th><th>Mensagem</th><th>Status</th><th>Data</th></tr></thead>
        <tbody>
          <% recent.forEach(function(m) { %>
          <tr>
            <td><%= m.phone %></td>
            <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= m.message %></td>
            <td><span class="badge badge-<%= m.status === 'sent' ? 'success' : 'danger' %>"><%= m.status %></span></td>
            <td><%= m.sent_at %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
<style>
.stat-card { background:var(--card-bg,#fff); border:1px solid var(--border,#ddd); border-radius:8px; padding:20px; text-align:center; }
.stat-value { font-size:28px; font-weight:700; color:#25D366; }
.stat-label { font-size:13px; color:#666; margin-top:4px; }
.badge-success { background:#e8f5e9; color:#2e7d32; padding:3px 10px; border-radius:12px; font-size:12px; }
.badge-danger { background:#ffebee; color:#c62828; padding:3px 10px; border-radius:12px; font-size:12px; }
.btn-secondary { background:#f5f5f5; color:#333; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:13px; }
.btn-secondary:hover { background:#e0e0e0; }
</style>
<%- include('../partials/admin-footer') %>
