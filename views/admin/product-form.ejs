<%- include('../partials/admin-header') %>

<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-<%= product ? 'edit' : 'plus' %>"></i> <%= product ? 'Editar' : 'Novo' %> Produto</h1>
    <a href="/admin/products" class="btn-secondary">
      <i class="fas fa-arrow-left"></i> Voltar
    </a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="form-card">
    <form action="/admin/products/<%= product ? 'edit/' + product.id : 'new' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Nome do Produto *</label>
          <input type="text" id="name" name="name" value="<%= product ? product.name : '' %>" required placeholder="Ex: iPhone 14 Pro Max">
        </div>
        <div class="form-group">
          <label for="price">Preço *</label>
          <input type="number" id="price" name="price" step="0.01" min="0" value="<%= product ? product.price : '' %>" required placeholder="0,00">
        </div>
      </div>

      <div class="form-group">
        <label for="description">Descrição</label>
        <textarea id="description" name="description" rows="5" placeholder="Descreva o produto em detalhes..."><%= product ? product.description : '' %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="category_id">Categoria</label>
          <select id="category_id" name="category_id">
            <option value="">Sem categoria</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>><%= cat.icon || '📦' %> <%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="condition">Condição</label>
          <select id="condition" name="condition">
            <option value="new" <%= product && product.condition === 'new' ? 'selected' : '' %>>Novo</option>
            <option value="semi-new" <%= product && product.condition === 'semi-new' ? 'selected' : '' %>>Semi-novo</option>
            <option value="used" <%= product && product.condition === 'used' ? 'selected' : '' %>>Usado</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="seller_id">Vendedor</label>
        <select id="seller_id" name="seller_id">
          <option value="">Admin (sem vendedor)</option>
          <% if (typeof sellers !== 'undefined' && sellers.length > 0) { %>
            <% sellers.forEach(s => { %>
              <option value="<%= s.id %>" <%= product && product.seller_id == s.id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          <% } %>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="location">Localização</label>
          <input type="text" id="location" name="location" value="<%= product ? product.location : 'Brasil' %>" placeholder="Ex: São Paulo, SP">
        </div>
        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="active" <%= product && product.status === 'active' ? 'selected' : '' %>>Ativo</option>
            <option value="pending" <%= product && product.status === 'pending' ? 'selected' : '' %>>Pendente</option>
            <option value="rejected" <%= product && product.status === 'rejected' ? 'selected' : '' %>>Rejeitado</option>
            <option value="inactive" <%= product && product.status === 'inactive' ? 'selected' : '' %>>Inativo</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="image">Imagem do Produto</label>
        <% if (product && product.image) { %>
          <div class="current-image">
            <img src="<%= product.image %>" alt="Imagem atual" style="max-width: 200px; border-radius: 8px;">
            <p>Imagem atual. Envie uma nova para substituir.</p>
          </div>
        <% } %>
        <input type="file" id="image" name="image" accept="image/*">
      </div>

      <div class="form-group checkbox-group">
        <label class="checkbox-label">
          <input type="checkbox" name="featured" value="1" <%= product && product.featured ? 'checked' : '' %>>
          <i class="fas fa-star"></i> Produto em Destaque
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">
          <i class="fas fa-save"></i> <%= product ? 'Salvar Alterações' : 'Criar Produto' %>
        </button>
        <a href="/admin/products" class="btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/admin-footer') %>
