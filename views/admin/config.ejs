<%- include('../partials/admin-header', { title: title, currentPath: '/admin/config' }) %>

<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-cog"></i> Configurações do Site</h1>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <form method="POST" action="/admin/config">
    <div class="form-card" style="margin-bottom:20px;">
      <h3><i class="fas fa-globe"></i> Informações Gerais</h3>
      <div class="form-row">
        <div class="form-group">
          <label>Nome do Site</label>
          <input type="text" name="site_name" value="<%= config.site_name || 'SeraTecnologia' %>" class="admin-input" required>
        </div>
        <div class="form-group">
          <label>Email de Contato</label>
          <input type="email" name="site_email" value="<%= config.site_email || '' %>" class="admin-input">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group" style="flex:1;">
          <label>Descrição do Site</label>
          <input type="text" name="site_description" value="<%= config.site_description || '' %>" class="admin-input">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>WhatsApp Geral (com DDD, apenas números)</label>
          <input type="text" name="site_whatsapp" value="<%= config.site_whatsapp || '' %>" class="admin-input" placeholder="5511999999999">
        </div>
        <div class="form-group">
          <label>Chave PIX da Plataforma</label>
          <input type="text" name="pix_key_platform" value="<%= config.pix_key_platform || '' %>" class="admin-input">
        </div>
      </div>
    </div>

    <div class="form-card" style="margin-bottom:20px;">
      <h3><i class="fas fa-dollar-sign"></i> Financeiro</h3>
      <div class="form-row">
        <div class="form-group">
          <label>Comissão Padrão (%)</label>
          <input type="number" name="commission_pct" value="<%= config.commission_pct || '10' %>" class="admin-input" min="0" max="100" step="0.1" required>
        </div>
        <div class="form-group">
          <label>Mercado Pago Access Token</label>
          <input type="password" name="mp_access_token" value="<%= config.mp_access_token || '' %>" class="admin-input" placeholder="Deixe vazio para desativar">
        </div>
      </div>
    </div>

    <div class="form-card" style="margin-bottom:20px;">
      <h3><i class="fas fa-code"></i> CSS / JS Personalizado</h3>
      <div class="form-row">
        <div class="form-group" style="flex:1;">
          <label>CSS Customizado</label>
          <textarea name="custom_css" class="admin-input" rows="4" style="font-family:monospace;font-size:13px;"><%= config.custom_css || '' %></textarea>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group" style="flex:1;">
          <label>JavaScript Customizado</label>
          <textarea name="custom_js" class="admin-input" rows="4" style="font-family:monospace;font-size:13px;"><%= config.custom_js || '' %></textarea>
        </div>
      </div>
    </div>

    <div class="form-card" style="margin-bottom:20px;">
      <h3><i class="fas fa-sliders-h"></i> Comportamento</h3>
      <div class="form-row">
        <div class="form-group">
          <label>Status Padrão de Produtos Novos</label>
          <select name="default_product_status" class="admin-select">
            <option value="pending" <%= config.default_product_status === 'pending' ? 'selected' : '' %>>Pendente (precisa aprovação)</option>
            <option value="active" <%= config.default_product_status === 'active' ? 'selected' : '' %>>Ativo (direto)</option>
          </select>
        </div>
        <div class="form-group">
          <label>Modo de Manutenção</label>
          <select name="maintenance_mode" class="admin-select">
            <option value="0" <%= config.maintenance_mode === '0' ? 'selected' : '' %>>Desativado</option>
            <option value="1" <%= config.maintenance_mode === '1' ? 'selected' : '' %>>Ativado (site fora do ar)</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Máx. Produtos por Vendedor</label>
          <input type="number" name="max_products_per_seller" value="<%= config.max_products_per_seller || '50' %>" class="admin-input" min="1" max="1000">
        </div>
      </div>
    </div>

    <div style="display:flex;gap:12px;margin-top:20px;">
      <button type="submit" class="btn-primary" style="padding:12px 32px;font-size:16px;">
        <i class="fas fa-save"></i> Salvar Configurações
      </button>
    </div>
  </form>

  <div class="form-card" style="margin-top:30px;">
    <h3><i class="fas fa-database"></i> Informações do Sistema</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;">
      <div style="padding:12px;background:#f5f5f5;border-radius:8px;">
        <div style="font-size:12px;color:#999;">Ambiente</div>
        <div style="font-weight:600;"><%= process.env.NODE_ENV || 'development' %></div>
      </div>
      <div style="padding:12px;background:#f5f5f5;border-radius:8px;">
        <div style="font-size:12px;color:#999;">URL Base</div>
        <div style="font-weight:600;"><%= process.env.BASE_URL || 'https://seratecnologia-1.onrender.com' %></div>
      </div>
      <div style="padding:12px;background:#f5f5f5;border-radius:8px;">
        <div style="font-size:12px;color:#999;">Versão Node</div>
        <div style="font-weight:600;"><%= process.version %></div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>