<%- include('../partials/admin-header') %>

<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-store-alt"></i> Vendedores</h1>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="form-card">
    <h3><i class="fas fa-user-plus"></i> Novo Vendedor</h3>
    <form action="/admin/sellers/new" method="POST" class="admin-form">
      <div class="form-row">
        <div class="form-group">
          <input type="text" name="name" placeholder="Nome do vendedor" required>
        </div>
        <div class="form-group">
          <input type="email" name="email" placeholder="Email (usado para login)" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <input type="text" name="phone" placeholder="Telefone">
        </div>
        <div class="form-group">
          <input type="password" name="password" placeholder="Senha" required>
        </div>
      </div>
      <button type="submit" class="btn-primary"><i class="fas fa-plus"></i> Criar Vendedor</button>
    </form>
  </div>

  <div class="table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Email</th>
          <th>Telefone</th>
          <th>Status</th>
          <th>Produtos</th>
          <th>Ativos</th>
          <th>Cadastro</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% sellers.forEach(s => { %>
          <tr>
            <td><strong><%= s.name %></strong></td>
            <td><%= s.email %></td>
            <td><%= s.phone || '-' %></td>
            <td><span class="status-badge <%= s.status %>"><%= s.status === 'active' ? 'Ativo' : 'Inativo' %></span></td>
            <td><%= s.product_count || 0 %></td>
            <td><%= s.active_count || 0 %></td>
            <td><%= new Date(s.created_at).toLocaleDateString('pt-BR') %></td>
            <td class="actions-cell">
              <form action="/admin/sellers/toggle/<%= s.id %>" method="POST" class="inline-form" onsubmit="return confirm('<%= s.status === 'active' ? 'Desativar' : 'Ativar' %> este vendedor?')">
                <button type="submit" class="btn-icon" title="<%= s.status === 'active' ? 'Desativar' : 'Ativar' %>">
                  <i class="fas fa-<%= s.status === 'active' ? 'ban' : 'check' %>"></i>
                </button>
              </form>
              <form action="/admin/sellers/delete/<%= s.id %>" method="POST" class="inline-form" onsubmit="return confirm('Excluir este vendedor? Os produtos dele serão removidos.')">
                <button type="submit" class="btn-icon btn-delete" title="Excluir"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/admin-footer') %>
