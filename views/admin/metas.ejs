<%- include('../partials/admin-header') %>
<div class="admin-content">
  <div class="page-header">
    <div>
      <h1><i class="fas fa-bullseye"></i> Metas dos Vendedores</h1>
      <p>Crie e gerencie metas de vendas e faturamento para os vendedores</p>
    </div>
  </div>

  <% if (success) { %>
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
  <% } %>

  <div class="form-card">
    <h3><i class="fas fa-plus-circle" style="color:var(--primary);"></i> Nova Meta</h3>
    <form method="POST" action="/admin/metas/novo" class="admin-form">
      <div class="form-row form-row-3">
        <div class="form-group">
          <label><i class="fas fa-tag"></i> Título</label>
          <input type="text" name="title" class="admin-input" required placeholder="Ex: Meta de Julho">
        </div>
        <div class="form-group">
          <label><i class="fas fa-chart-bar"></i> Tipo</label>
          <select name="type" class="admin-select">
            <option value="sales_count">Qtd de Vendas</option>
            <option value="revenue">Faturamento (R$)</option>
          </select>
        </div>
        <div class="form-group">
          <label><i class="fas fa-bullseye"></i> Valor da Meta</label>
          <input type="number" name="target_value" class="admin-input" step="0.01" min="1" required>
        </div>
        <div class="form-group">
          <label><i class="fas fa-calendar-start"></i> Data Início</label>
          <input type="date" name="start_date" class="admin-input" required>
        </div>
        <div class="form-group">
          <label><i class="fas fa-calendar-end"></i> Data Fim</label>
          <input type="date" name="end_date" class="admin-input" required>
        </div>
        <div class="form-group">
          <label><i class="fas fa-gift"></i> Prêmio</label>
          <input type="text" name="prize_description" class="admin-input" placeholder="Ex: R$ 50 no Pix">
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-primary"><i class="fas fa-plus"></i> Criar Meta</button>
      </div>
    </form>
  </div>

  <div class="admin-section">
    <div class="section-header">
      <h2><i class="fas fa-list"></i> Metas Cadastradas</h2>
    </div>
    <div class="table-container">
      <table class="admin-table">
        <thead>
          <tr><th>Título</th><th>Tipo</th><th>Meta</th><th>Prêmio</th><th>Período</th><th>Ativa</th><th>Ações</th></tr>
        </thead>
        <tbody>
          <% if (goals.length === 0) { %>
            <tr><td colspan="7" class="empty-row">Nenhuma meta cadastrada</td></tr>
          <% } %>
          <% goals.forEach(function(g) { %>
            <tr>
              <td><strong><%= g.title %></strong></td>
              <td><%= g.type === 'sales_count' ? '📦 Vendas' : '💰 Faturamento' %></td>
              <td class="price-cell"><%= g.type === 'sales_count' ? g.target_value + ' vendas' : 'R$ ' + parseFloat(g.target_value).toFixed(2) %></td>
              <td><%= g.prize_description || '-' %></td>
              <td><%= g.start_date.split('-').reverse().join('/') %> a <%= g.end_date.split('-').reverse().join('/') %></td>
              <td>
                <form method="POST" action="/admin/metas/toggle/<%= g.id %>" style="display:inline;">
                  <span class="status-badge <%= g.active ? 'active' : 'inactive' %>" style="cursor:pointer;" onclick="this.closest('form').submit()"><%= g.active ? 'Ativa' : 'Inativa' %></span>
                </form>
              </td>
              <td class="actions-cell">
                <a href="/admin/placar?goal_id=<%= g.id %>" class="btn-icon" title="Ver Placar"><i class="fas fa-ranking-star"></i></a>
                <form method="POST" action="/admin/metas/deletar/<%= g.id %>" style="display:inline;" onsubmit="return confirm('Excluir meta?')">
                  <button class="btn-icon btn-delete"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>