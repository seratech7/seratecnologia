<%- include('../partials/admin-header', { title: title, currentPath: '/admin/logs' }) %>
<div class="admin-content">
  <div class="admin-header-bar">
    <h1><i class="fas fa-history"></i> Registro de Atividades</h1>
  </div>
  <div class="table-wrapper">
    <table class="admin-table">
      <thead><tr><th>Data</th><th>Usuário</th><th>Ação</th><th>Detalhes</th><th>IP</th></tr></thead>
      <tbody>
        <% if (logs.length === 0) { %><tr><td colspan="5" class="empty-row">Nenhuma atividade registrada</td></tr><% } %>
        <% logs.forEach(function(l) { %>
          <tr>
            <td style="white-space:nowrap;font-size:12px;color:#666;"><%= new Date(l.created_at).toLocaleString('pt-BR') %></td>
            <td>
              <span class="status-badge small" style="background:<%= l.user_type === 'admin' ? '#e3f2fd' : '#fff3cd' %>;color:<%= l.user_type === 'admin' ? '#1565c0' : '#856404' %>;">
                <%= l.user_type === 'admin' ? 'Admin' : 'Vendedor' %>
              </span>
              <%= l.user_name ? '<br><span style="font-size:12px;">' + l.user_name + '</span>' : '' %>
            </td>
            <td style="font-family:monospace;font-size:12px;"><%= l.action %></td>
            <td style="font-size:13px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= l.details %></td>
            <td style="font-size:12px;color:#999;"><%= l.ip || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for (var p = 1; p <= totalPages; p++) { %>
        <a href="/admin/logs?page=<%= p %>" class="page-link <%= p === page ? 'active' : '' %>"><%= p %></a>
      <% } %>
    </div>
  <% } %>
</div>
<%- include('../partials/admin-footer') %>