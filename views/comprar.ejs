<%- include('partials/header') %>

<div class="container" style="max-width:800px;margin:0 auto;padding:24px 16px;">
  <div style="text-align:center;margin-bottom:32px;">
    <h1 style="margin:0;font-size:28px;"><i class="fas fa-shopping-cart"></i> Compra Online</h1>
    <p style="margin:8px 0 0;color:#666;">Digite o código do produto para iniciar</p>
  </div>

  <div style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:24px;margin-bottom:24px;">
    <form method="GET" action="/comprar" id="searchForm" style="display:flex;gap:8px;">
      <input type="text" name="codigo" id="codigoInput" value="<%= codigo %>" placeholder="Ex: PROD-00001" style="flex:1;padding:12px 16px;border:2px solid #ddd;border-radius:8px;font-size:16px;font-family:monospace;text-transform:uppercase;letter-spacing:1px;" autofocus>
      <button type="submit" style="padding:12px 24px;background:#1565c0;color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:600;cursor:pointer;white-space:nowrap;">
        <i class="fas fa-search"></i> Buscar
      </button>
    </form>
    <div style="margin-top:8px;font-size:13px;color:#999;text-align:center;">
      <i class="fas fa-info-circle"></i> Informe o código que está na etiqueta do produto (ex: PROD-00001)
    </div>
  </div>

  <% if (error) { %>
  <div style="background:#fdecea;color:#c62828;padding:16px 20px;border-radius:8px;margin-bottom:24px;text-align:center;">
    <i class="fas fa-exclamation-circle"></i> <%= error %>
  </div>
  <% } %>

  <% if (produto) { %>
  <div style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:24px;margin-bottom:24px;">
    <div style="display:flex;gap:20px;align-items:center;flex-wrap:wrap;">
      <% if (produto.image) { %>
        <img src="<%= produto.image %>" alt="<%= produto.name %>" style="width:120px;height:120px;object-fit:cover;border-radius:8px;background:#f5f5f5;">
      <% } else { %>
        <div style="width:120px;height:120px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:36px;"><i class="fas fa-image"></i></div>
      <% } %>
      <div style="flex:1;min-width:200px;">
        <div style="font-family:monospace;font-size:13px;color:#1565c0;font-weight:700;margin-bottom:4px;"><%= produto.code %></div>
        <h2 style="margin:0 0 8px;font-size:20px;"><%= produto.name %></h2>
        <div style="font-size:28px;font-weight:800;color:#1565c0;">
          <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(produto.price) %>
        </div>
        <div style="font-size:14px;color:#888;margin-top:4px;">
          <i class="fas fa-store"></i> <%= produto.seller_name || 'Vendedor' %>
          <% if (produto.seller_pix) { %> &middot; <i class="fas fa-pix" style="color:#00a844;"></i> PIX disponível<% } %>
        </div>
        <div style="margin-top:4px;font-size:14px;color:#666;">
          <i class="fas fa-map-marker-alt"></i> <%= produto.location || 'Brasil' %>
        </div>
      </div>
    </div>
  </div>

  <div style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:24px;margin-bottom:24px;">
    <h3 style="margin:0 0 16px;"><i class="fas fa-user"></i> Dados do Comprador</h3>
    <form id="buyerForm" onsubmit="return gerarPagamento(event)">
      <input type="hidden" name="product_code" value="<%= produto.code %>">

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div style="grid-column:1/-1;">
          <label style="display:block;font-size:14px;font-weight:600;color:#444;margin-bottom:4px;">Nome Completo *</label>
          <input type="text" name="nome" id="buyerNome" required style="width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:15px;">
        </div>
        <div>
          <label style="display:block;font-size:14px;font-weight:600;color:#444;margin-bottom:4px;">CPF/CNPJ *</label>
          <input type="text" name="documento" required style="width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:15px;">
        </div>
        <div>
          <label style="display:block;font-size:14px;font-weight:600;color:#444;margin-bottom:4px;">Telefone/WhatsApp *</label>
          <input type="tel" name="telefone" required style="width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:15px;">
        </div>
        <div style="grid-column:1/-1;">
          <label style="display:block;font-size:14px;font-weight:600;color:#444;margin-bottom:4px;">E-mail *</label>
          <input type="email" name="email" required style="width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:15px;">
        </div>
        <div style="grid-column:1/-1;">
          <label style="display:block;font-size:14px;font-weight:600;color:#444;margin-bottom:4px;">Endereço Completo *</label>
          <input type="text" name="endereco" required placeholder="Rua, número, bairro, cidade, estado, CEP" style="width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:15px;">
        </div>
      </div>

      <div id="pixErro" style="display:none;background:#fdecea;color:#c62828;padding:12px 16px;border-radius:8px;margin-top:16px;font-size:14px;"></div>

      <div style="margin-top:20px;">
        <button type="submit" id="btnGerarPix" style="width:100%;padding:14px;background:#00c853;color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:700;cursor:pointer;transition:background .2s;">
          <i class="fas fa-qrcode"></i> Gerar QR Code PIX
        </button>
      </div>
    </form>
  </div>

  <div id="pixSection" style="display:none;background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:32px;text-align:center;margin-bottom:24px;">
    <h3 style="margin:0 0 8px;"><i class="fas fa-qrcode"></i> Pagamento via PIX</h3>
    <p style="color:#666;margin:0 0 8px;">Escaneie o QR Code abaixo para pagar</p>
    <p style="font-size:14px;color:#888;margin:0 0 24px;">
      Pagamento para <strong id="pixSellerName"></strong>
    </p>

    <div id="pixQrContainer" style="display:inline-block;background:#fff;padding:16px;border-radius:12px;border:2px solid #e0e0e0;">
      <img id="pixQrImage" src="" alt="QR Code PIX" style="width:240px;height:240px;display:block;">
    </div>

    <div style="margin-top:16px;">
      <button onclick="copiarChave()" style="padding:10px 20px;background:#fff;color:#1565c0;border:2px solid #1565c0;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">
        <i class="fas fa-copy"></i> Copiar chave PIX
      </button>
    </div>
    <div id="pixChaveDisplay" style="margin-top:8px;font-family:monospace;font-size:13px;color:#999;word-break:break-all;"></div>

    <div id="resumoCompra" style="margin-top:20px;text-align:left;background:#f9f9f9;border-radius:8px;padding:16px;">
      <h4 style="margin:0 0 12px;font-size:14px;color:#666;">Resumo da Compra</h4>
      <div style="font-size:14px;line-height:1.8;" id="resumoDados"></div>
    </div>

    <button onclick="window.print()" style="margin-top:16px;padding:10px 20px;background:#fff;color:#1565c0;border:2px solid #1565c0;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">
      <i class="fas fa-print"></i> Imprimir Comprovante
    </button>
  </div>
  <% } %>
</div>

<script>
var ultimoPayload = '';

function gerarPagamento(e) {
  e.preventDefault();
  var btn = document.getElementById('btnGerarPix');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Gerando...';
  document.getElementById('pixErro').style.display = 'none';

  var form = document.getElementById('buyerForm');
  var dados = {
    codigo: '<%= produto ? produto.code : "" %>',
    nome: form.nome.value,
    documento: form.documento.value,
    telefone: form.telefone.value,
    email: form.email.value,
    endereco: form.endereco.value
  };

  fetch('/api/gerar-pix', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ codigo: dados.codigo, nome: dados.nome })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.error) {
      document.getElementById('pixErro').textContent = data.error;
      document.getElementById('pixErro').style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-qrcode"></i> Gerar QR Code PIX';
      return;
    }

    document.getElementById('pixQrImage').src = data.qrcode;
    document.getElementById('pixSellerName').textContent = data.sellerName;
    document.getElementById('pixChaveDisplay').textContent = 'Chave: ' + data.chave;
    ultimoPayload = data.payload;

    var resumo = document.getElementById('resumoDados');
    resumo.innerHTML =
      '<strong>Produto:</strong> <%= produto ? produto.name.replace(/'/g, "\\'") : "" %><br>' +
      '<strong>Código:</strong> ' + dados.codigo + '<br>' +
      '<strong>Valor:</strong> ' + parseFloat(data.valor).toLocaleString('pt-BR', {style:'currency',currency:'BRL'}) + '<br>' +
      '<strong>Vendedor:</strong> ' + data.sellerName + '<br>' +
      '<strong>Comprador:</strong> ' + dados.nome + '<br>' +
      '<strong>CPF/CNPJ:</strong> ' + dados.documento + '<br>' +
      '<strong>WhatsApp:</strong> ' + dados.telefone + '<br>' +
      '<strong>E-mail:</strong> ' + dados.email + '<br>' +
      '<strong>Endereço:</strong> ' + dados.endereco;

    document.getElementById('pixSection').style.display = 'block';
    document.getElementById('pixSection').scrollIntoView({ behavior: 'smooth' });
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-qrcode"></i> Gerar QR Code PIX';

    fetch('/api/finalizar-compra', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(dados)
    }).then(function(r) { return r.json(); }).then(function(resp) {
      var sellerWa = '<%= produto && produto.seller_whatsapp ? produto.seller_whatsapp.replace(/\D/g, "") : "" %>';
      if (resp.success) {
        var waLink = '';
        if (sellerWa) {
          var waMsg = encodeURIComponent('Olá! Acabei de comprar o produto ' + dados.codigo + '. Meu WhatsApp é ' + dados.telefone);
          waLink = '<a href="https://wa.me/55' + sellerWa + '?text=' + waMsg + '" target="_blank" style="display:inline-flex;align-items:center;gap:8px;margin-top:12px;padding:12px 24px;background:#25D366;color:#fff;border-radius:8px;text-decoration:none;font-weight:700;font-size:15px;">' +
            '<i class="fab fa-whatsapp"></i> Falar com Vendedor no WhatsApp</a>';
        }
        var trackingHtml = '<div style="margin-top:16px;padding:16px;background:#e8f5e9;border-radius:8px;text-align:center;">' +
          '<i class="fas fa-check-circle" style="color:#2e7d32;font-size:24px;"></i>' +
          '<p style="font-weight:700;color:#2e7d32;margin:8px 0 4px;">Compra registrada com sucesso!</p>' +
          '<p style="font-size:13px;color:#555;margin:4px 0;">Código de rastreio:</p>' +
          '<p style="font-size:18px;font-weight:800;color:#1565c0;font-family:monospace;letter-spacing:1px;margin:4px 0;">' + resp.trackingCode + '</p>' +
          '<a href="/rastreio?codigo=' + resp.trackingCode + '" style="display:inline-block;margin-top:8px;padding:8px 16px;background:#1565c0;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;">' +
          '<i class="fas fa-truck"></i> Acompanhar Pedido</a>' +
          waLink +
          '<p style="font-size:12px;color:#999;margin-top:8px;">Você também receberá atualizações por WhatsApp e email</p>' +
        '</div>';
        document.querySelector('#pixSection').insertAdjacentHTML('beforeend', trackingHtml);
      }
    }).catch(function() {});
  }).catch(function() {
    document.getElementById('pixErro').textContent = 'Erro ao gerar PIX. Tente novamente.';
    document.getElementById('pixErro').style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-qrcode"></i> Gerar QR Code PIX';
  });
}

function copiarChave() {
  if (ultimoPayload) {
    navigator.clipboard.writeText(ultimoPayload).then(function() {
      alert('Código PIX copiado!');
    }).catch(function() {
      prompt('Copie o código PIX abaixo:', ultimoPayload);
    });
  }
}

document.getElementById('codigoInput').addEventListener('keyup', function(e) {
  this.value = this.value.toUpperCase();
});
</script>

<style>
@media(max-width:600px) {
  #buyerForm div[style*="grid-template-columns"] { grid-template-columns:1fr !important; }
  #searchForm { flex-direction:column; }
  #searchForm button { width:100%; }
  #pixQrContainer img { width:200px !important; height:200px !important; }
}
</style>

<%- include('partials/footer') %>