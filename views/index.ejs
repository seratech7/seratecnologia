<%- include('partials/header') %>

<%
function q(urlParams) {
  var p = [];
  if (search) p.push('search=' + encodeURIComponent(search));
  if (selectedCategory) p.push('category=' + encodeURIComponent(selectedCategory));
  if (selectedCondition) p.push('condition=' + encodeURIComponent(selectedCondition));
  if (priceMin) p.push('price_min=' + encodeURIComponent(priceMin));
  if (priceMax) p.push('price_max=' + encodeURIComponent(priceMax));
  if (selectedSort) p.push('sort=' + encodeURIComponent(selectedSort));
  return p.length ? '?' + p.join('&') : '/';
}
%>

<div class="marketplace-container">
  <button class="filter-toggle" id="filterToggle"><i class="fas fa-filter"></i> Filtros</button>
  <aside class="sidebar-filters" id="sidebarFilters">
    <form method="GET" action="/" class="filter-form" id="filterForm">
      <% if (search) { %><input type="hidden" name="search" value="<%= search %>"><% } %>

      <div class="filter-section">
        <h3><i class="fas fa-filter"></i> Filtros</h3>
        <a href="/" class="clear-filters"><i class="fas fa-times-circle"></i> Limpar filtros</a>
      </div>

      <div class="filter-section">
        <h4>Categorias</h4>
        <ul class="category-list">
          <li>
            <label class="filter-label <%= !selectedCategory ? 'active' : '' %>">
              <input type="radio" name="category" value="" <%= !selectedCategory ? 'checked' : '' %> onchange="this.form.submit()">
              <i class="fas fa-th-large"></i> Todas
            </label>
          </li>
          <% categories.forEach(cat => { %>
            <li>
              <label class="filter-label <%= selectedCategory === cat.slug ? 'active' : '' %>">
                <input type="radio" name="category" value="<%= cat.slug %>" <%= selectedCategory === cat.slug ? 'checked' : '' %> onchange="this.form.submit()">
                <%= cat.icon || '📦' %> <%= cat.name %>
              </label>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="filter-section">
        <h4>Condição</h4>
        <ul class="condition-list">
          <li>
            <label class="filter-label <%= !selectedCondition ? 'active' : '' %>">
              <input type="radio" name="condition" value="" <%= !selectedCondition ? 'checked' : '' %> onchange="this.form.submit()">
              Todas
            </label>
          </li>
          <li>
            <label class="filter-label <%= selectedCondition === 'new' ? 'active' : '' %>">
              <input type="radio" name="condition" value="new" <%= selectedCondition === 'new' ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="cond-dot new"></span> Novo
            </label>
          </li>
          <li>
            <label class="filter-label <%= selectedCondition === 'open-box' ? 'active' : '' %>">
              <input type="radio" name="condition" value="open-box" <%= selectedCondition === 'open-box' ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="cond-dot open-box"></span> Aberto
            </label>
          </li>
          <li>
            <label class="filter-label <%= selectedCondition === 'semi-new' ? 'active' : '' %>">
              <input type="radio" name="condition" value="semi-new" <%= selectedCondition === 'semi-new' ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="cond-dot semi-new"></span> Semi-novo
            </label>
          </li>
          <li>
            <label class="filter-label <%= selectedCondition === 'used' ? 'active' : '' %>">
              <input type="radio" name="condition" value="used" <%= selectedCondition === 'used' ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="cond-dot used"></span> Usado
            </label>
          </li>
          <li>
            <label class="filter-label <%= selectedCondition === 'refurbished' ? 'active' : '' %>">
              <input type="radio" name="condition" value="refurbished" <%= selectedCondition === 'refurbished' ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="cond-dot refurbished"></span> Recondicionado
            </label>
          </li>
        </ul>
      </div>

      <div class="filter-section">
        <h4>Faixa de Preço</h4>
        <div class="price-range">
          <div class="price-inputs">
            <input type="number" name="price_min" placeholder="R$ min" value="<%= priceMin %>" class="price-field" min="0" step="0.01">
            <span class="price-sep">—</span>
            <input type="number" name="price_max" placeholder="R$ max" value="<%= priceMax %>" class="price-field" min="0" step="0.01">
          </div>
          <button type="submit" class="btn-price-apply">Aplicar</button>
        </div>
      </div>

      <div class="filter-section">
        <h4>Ordenar</h4>
        <select name="sort" class="sort-select" onchange="this.form.submit()">
          <option value="" <%= !selectedSort ? 'selected' : '' %>>Mais recentes</option>
          <option value="price_asc" <%= selectedSort === 'price_asc' ? 'selected' : '' %>>Menor preço</option>
          <option value="price_desc" <%= selectedSort === 'price_desc' ? 'selected' : '' %>>Maior preço</option>
          <option value="oldest" <%= selectedSort === 'oldest' ? 'selected' : '' %>>Mais antigos</option>
        </select>
      </div>
    </form>
  </aside>

  <section class="products-section">
    <div class="products-header">
      <h2>
        <% if (search) { %>
          Resultados para "<%= search %>"
        <% } else if (selectedCategory) { %>
          <% const cat = categories.find(c => c.slug === selectedCategory) %>
          <%= cat ? cat.icon + ' ' + cat.name : 'Produtos' %>
        <% } else { %>
          <i class="fas fa-microchip"></i> Tecnologia em Destaque
        <% } %>
      </h2>
      <div class="products-header-info">
        <span class="products-count"><%= products.length %> produto(s)</span>
        <select class="sort-select-mobile" onchange="var p=new URLSearchParams(location.search);p.set('sort',this.value);location='?'+p.toString()">
          <option value="" <%= !selectedSort ? 'selected' : '' %>>Recentes</option>
          <option value="price_asc" <%= selectedSort === 'price_asc' ? 'selected' : '' %>>Menor preço</option>
          <option value="price_desc" <%= selectedSort === 'price_desc' ? 'selected' : '' %>>Maior preço</option>
        </select>
      </div>
    </div>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-box-open"></i>
        <h3>Nenhum produto encontrado</h3>
        <p>Tente buscar por outros termos ou navegue pelas categorias.</p>
        <a href="/" class="btn-empty-reset"><i class="fas fa-times-circle"></i> Limpar filtros</a>
      </div>
    <% } else { %>
      <div class="products-grid">
        <% products.forEach(product => { %>
          <a href="/produto/<%= product.id %>" class="product-card">
            <div class="product-image">
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>">
              <% } else { %>
                <div class="no-image">
                  <i class="fas fa-image"></i>
                </div>
              <% } %>
              <% if (product.featured) { %>
                <span class="featured-badge"><i class="fas fa-star"></i> Destaque</span>
              <% } %>
              <% var condClass = product.condition || 'new'; %>
              <% if (condClass === 'new') { %>
                <span class="condition-badge new">Novo</span>
              <% } else if (condClass === 'open-box') { %>
                <span class="condition-badge" style="background:#ff9800;">Aberto</span>
              <% } else if (condClass === 'semi-new') { %>
                <span class="condition-badge" style="background:#7c4dff;">Semi-novo</span>
              <% } else if (condClass === 'refurbished') { %>
                <span class="condition-badge" style="background:#009688;">Recondicionado</span>
              <% } else { %>
                <span class="condition-badge used">Usado</span>
              <% } %>
            </div>
            <div class="product-info">
              <h3 class="product-name"><%= product.name %></h3>
              <p class="product-price">
                <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(product.price) %>
              </p>
              <div class="product-meta">
                <span class="product-location">
                  <i class="fas fa-map-marker-alt"></i> <%= product.location || 'Brasil' %>
                </span>
                <% if (product.category_name) { %>
                  <span class="product-category"><%= product.category_name %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var toggle = document.getElementById('filterToggle');
  var sidebar = document.getElementById('sidebarFilters');
  if (toggle && sidebar) {
    toggle.addEventListener('click', function() {
      sidebar.classList.toggle('active');
    });
  }
});
</script>

<%- include('partials/footer') %>
