<%- include('partials/header') %>

<div class="marketplace-container">
  <aside class="sidebar-filters">
    <div class="filter-section">
      <h3><i class="fas fa-filter"></i> Filtros</h3>
    </div>

    <div class="filter-section">
      <h4>Categorias</h4>
      <ul class="category-list">
        <li>
          <a href="/" class="<%= !selectedCategory ? 'active' : '' %>">
            <i class="fas fa-th-large"></i> Todas
          </a>
        </li>
        <% categories.forEach(cat => { %>
          <li>
            <a href="/?category=<%= cat.slug %><%= search ? '&search=' + search : '' %>" class="<%= selectedCategory === cat.slug ? 'active' : '' %>">
              <%= cat.icon || '📦' %> <%= cat.name %>
            </a>
          </li>
        <% }) %>
      </ul>
    </div>

    <div class="filter-section">
      <h4>Condição</h4>
      <ul class="condition-list">
        <li>
          <a href="/<%= selectedCategory ? '?category=' + selectedCategory : '' %>" class="<%= !selectedCondition ? 'active' : '' %>">
            Todas
          </a>
        </li>
        <li>
          <a href="/?condition=new<%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %>" class="<%= selectedCondition === 'new' ? 'active' : '' %>">
            Novo
          </a>
        </li>
        <li>
          <a href="/?condition=semi-new<%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %>" class="<%= selectedCondition === 'semi-new' ? 'active' : '' %>">
            Semi-novo
          </a>
        </li>
        <li>
          <a href="/?condition=used<%= selectedCategory ? '&category=' + selectedCategory : '' %><%= search ? '&search=' + search : '' %>" class="<%= selectedCondition === 'used' ? 'active' : '' %>">
            Usado
          </a>
        </li>
      </ul>
    </div>
  </aside>

  <section class="products-section">
    <div class="products-header">
      <h2>
        <% if (search) { %>
          Resultados para "<%= search %>"
        <% } else if (selectedCategory) { %>
          <% const cat = categories.find(c => c.slug === selectedCategory) %>
          <%= cat ? cat.icon + ' ' + cat.name : 'Produtos' %>
        <% } else { %>
          <i class="fas fa-microchip"></i> Tecnologia em Destaque
        <% } %>
      </h2>
      <span class="products-count"><%= products.length %> produto(s)</span>
    </div>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-box-open"></i>
        <h3>Nenhum produto encontrado</h3>
        <p>Tente buscar por outros termos ou navegue pelas categorias.</p>
      </div>
    <% } else { %>
      <div class="products-grid">
        <% products.forEach(product => { %>
          <a href="/produto/<%= product.id %>" class="product-card">
            <div class="product-image">
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="<%= product.name %>">
              <% } else { %>
                <div class="no-image">
                  <i class="fas fa-image"></i>
                </div>
              <% } %>
              <% if (product.featured) { %>
                <span class="featured-badge"><i class="fas fa-star"></i> Destaque</span>
              <% } %>
              <% if (product.condition === 'new') { %>
                <span class="condition-badge new">Novo</span>
              <% } else if (product.condition === 'semi-new') { %>
                <span class="condition-badge" style="background:#7c4dff;">Semi-novo</span>
              <% } else { %>
                <span class="condition-badge used">Usado</span>
              <% } %>
            </div>
            <div class="product-info">
              <h3 class="product-name"><%= product.name %></h3>
              <p class="product-price">
                <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(product.price) %>
              </p>
              <div class="product-meta">
                <span class="product-location">
                  <i class="fas fa-map-marker-alt"></i> <%= product.location || 'Brasil' %>
                </span>
                <% if (product.category_name) { %>
                  <span class="product-category"><%= product.category_name %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>
