<%- include('partials/header') %>

<div class="container" style="max-width:800px;margin:0 auto;padding:24px 16px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
      <h1 style="margin:0;font-size:24px;"><i class="fas fa-bell"></i> Notificações</h1>
      <p style="margin:4px 0 0;color:#666;font-size:14px;"><%= total %> notificação<%= total !== 1 ? 'ões' : '' %> • <%= unread %> não lida<%= unread !== 1 ? 's' : '' %></p>
    </div>
    <% if (unread > 0) { %>
      <button class="btn-primary" onclick="marcarTodas()" style="padding:8px 16px;font-size:13px;">
        <i class="fas fa-check-double"></i> Marcar todas como lidas
      </button>
    <% } %>
  </div>

  <% if (notifications.length === 0) { %>
  <div style="text-align:center;padding:80px 20px;color:#999;">
    <i class="fas fa-bell-slash" style="font-size:48px;opacity:0.3;margin-bottom:16px;"></i>
    <p style="font-size:16px;">Nenhuma notificação</p>
    <p style="font-size:14px;">As notificações aparecerão aqui quando houver novidades.</p>
  </div>
  <% } else { %>
  <div style="display:flex;flex-direction:column;gap:2px;">
    <% notifications.forEach(function(n) { %>
    <div class="notif-item <%= n.read ? 'notif-read' : 'notif-unread' %>" data-id="<%= n.id %>">
      <div class="notif-icon">
        <i class="fas fa-<%= n.icon || 'bell' %>"></i>
      </div>
      <div class="notif-body">
        <div class="notif-message">
          <% if (n.link) { %><a href="<%= n.link %>" style="text-decoration:none;color:inherit;"><% } %>
            <%= n.message %>
          <% if (n.link) { %></a><% } %>
        </div>
        <div class="notif-time"><%= n.created_at %></div>
      </div>
      <% if (!n.read) { %>
      <button class="notif-mark" onclick="marcarLida(<%= n.id %>)" title="Marcar como lida"><i class="fas fa-check"></i></button>
      <% } %>
    </div>
    <% }); %>
  </div>
  <% } %>

  <% if (totalPages > 1) { %>
  <div style="display:flex;gap:8px;justify-content:center;margin-top:24px;">
    <% for(var p=1;p<=totalPages;p++){ %>
      <a href="/notificacoes?page=<%= p %>" class="btn-small" style="<%= p===page?'background:var(--primary);color:#fff;':'' %>min-width:36px;text-align:center;text-decoration:none;"><%= p %></a>
    <% } %>
  </div>
  <% } %>
</div>

<script>
function marcarLida(id) {
  fetch('/api/notifications/read/' + id, { method: 'POST' }).then(function() {
    var el = document.querySelector('.notif-item[data-id="' + id + '"]');
    if (el) {
      el.classList.remove('notif-unread');
      el.classList.add('notif-read');
      el.querySelector('.notif-mark')?.remove();
    }
  });
}
function marcarTodas() {
  fetch('/api/notifications/read-all', { method: 'POST' }).then(function() {
    document.querySelectorAll('.notif-item.notif-unread').forEach(function(el) {
      el.classList.remove('notif-unread');
      el.classList.add('notif-read');
      var btn = el.querySelector('.notif-mark');
      if (btn) btn.remove();
    });
    document.querySelector('button .fa-check-double')?.closest('button')?.remove();
  });
}
</script>

<style>
.notif-item { display:flex; align-items:flex-start; gap:12px; padding:14px 16px; border-radius:8px; transition:background .15s; }
.notif-unread { background:#f0f7ff; }
.notif-read { background:transparent; }
.notif-item:hover { background:#f5f5f5; }
.notif-icon { width:36px; height:36px; border-radius:50%; background:#e3f2fd; color:#1565c0; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:14px; }
.notif-read .notif-icon { background:#f0f0f0; color:#999; }
.notif-body { flex:1; min-width:0; }
.notif-message { font-size:14px; line-height:1.4; color:#222; }
.notif-read .notif-message { color:#888; }
.notif-time { font-size:12px; color:#999; margin-top:4px; }
.notif-mark { background:none; border:none; color:#4caf50; cursor:pointer; padding:4px; font-size:14px; opacity:0; transition:opacity .15s; }
.notif-item:hover .notif-mark { opacity:1; }
@media(max-width:600px) {
  .notif-item { padding:12px; }
  .notif-message { font-size:13px; }
}
</style>

<%- include('partials/footer') %>