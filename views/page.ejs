<%- include('partials/header') %>
<div class="container" style="max-width:900px;margin:0 auto;padding:32px 16px;">
  <div class="breadcrumb" style="margin-bottom:24px;">
    <a href="/"><i class="fas fa-home"></i> Início</a>
    <span><i class="fas fa-chevron-right"></i></span>
    <span><%= page.title %></span>
  </div>
  <div class="page-content" style="background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);padding:32px;">
    <h1 style="margin:0 0 24px;font-size:28px;"><%= page.title %></h1>
    <div style="line-height:1.8;font-size:16px;color:#444;">
      <%- page.content %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>