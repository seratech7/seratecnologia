<%- include('../partials/admin-header') %>

<div class="dashboard-header">
  <h1><i class="fas fa-wallet"></i> Minha Carteira</h1>
  <p>Saldo e histórico financeiro</p>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px;">
  <div style="background:linear-gradient(135deg,#1565c0,#0d47a1);color:#fff;border-radius:12px;padding:24px;">
    <div style="font-size:14px;opacity:0.8;">Saldo Disponível</div>
    <div style="font-size:32px;font-weight:800;margin-top:4px;">
      <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(balance) %>
    </div>
    <div style="font-size:13px;opacity:0.7;margin-top:8px;">
      <i class="fas fa-shopping-bag"></i> <%= totalVendas %> venda(s)
    </div>
  </div>
  <div style="background:#fff;border-radius:12px;padding:24px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
    <div style="font-size:14px;color:#666;">Comissão Plataforma</div>
    <div style="font-size:28px;font-weight:800;color:#e65100;margin-top:4px;"><%= commPct %>%</div>
    <div style="font-size:13px;color:#999;margin-top:8px;">Valor retido por venda</div>
  </div>
</div>

<% if (txns.length === 0) { %>
<div style="text-align:center;padding:60px;color:#999;">
  <i class="fas fa-wallet" style="font-size:48px;opacity:0.3;margin-bottom:16px;"></i>
  <p>Nenhuma movimentação financeira ainda</p>
</div>
<% } else { %>
<div style="overflow-x:auto;background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
<table class="admin-table">
  <thead>
    <tr>
      <th>Data</th>
      <th>Descrição</th>
      <th>Tipo</th>
      <th>Valor</th>
      <th>Saldo</th>
    </tr>
  </thead>
  <tbody>
    <% txns.forEach(function(t) { %>
    <tr>
      <td style="font-size:12px;color:#666;white-space:nowrap;"><%= t.created_at %></td>
      <td><%= t.description %></td>
      <td>
        <% if (t.type === 'sale') { %><span style="background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:4px;font-size:12px;">Venda</span>
        <% } else if (t.type === 'commission') { %><span style="background:#fff3e0;color:#e65100;padding:2px 8px;border-radius:4px;font-size:12px;">Comissão</span>
        <% } else if (t.type === 'payout') { %><span style="background:#fce4ec;color:#c62828;padding:2px 8px;border-radius:4px;font-size:12px;">Saque</span>
        <% } else { %><span style="background:#f5f5f5;color:#666;padding:2px 8px;border-radius:4px;font-size:12px;"><%= t.type %></span><% } %>
      </td>
      <td style="font-weight:700;color:<%= t.amount >= 0 ? '#2e7d32' : '#c62828' %>;">
        <%= t.amount >= 0 ? '+' : '' %><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(t.amount) %>
      </td>
      <td style="font-weight:600;"><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(t.balance) %></td>
    </tr>
    <% }); %>
  </tbody>
</table>
</div>

<% if (totalPages > 1) { %>
<div style="display:flex;gap:8px;justify-content:center;margin-top:20px;">
  <% for(var p=1;p<=totalPages;p++){ %>
    <a href="/seller/wallet?page=<%= p %>" class="btn-small" style="<%= p===page?'background:var(--primary);color:#fff;':'' %>min-width:36px;text-align:center;text-decoration:none;"><%= p %></a>
  <% } %>
</div>
<% } %>
<% } %>

<%- include('../partials/admin-footer') %>