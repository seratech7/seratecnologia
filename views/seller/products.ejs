<%- include('../partials/seller-header') %>
<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-box"></i> Meus Produtos</h1>
    <a href="/seller/products/new" class="btn-primary"><i class="fas fa-plus"></i> Novo Produto</a>
  </div>
  <div style="margin-bottom:12px;display:flex;gap:8px;flex-wrap:wrap;">
    <a href="/seller/products" class="btn-secondary" style="font-size:13px;padding:6px 12px;">Todos</a>
    <a href="/seller/products?filter=active" class="btn-secondary" style="font-size:13px;padding:6px 12px;">Ativos</a>
    <a href="/seller/products?filter=pending" class="btn-secondary" style="font-size:13px;padding:6px 12px;">Pendentes</a>
    <a href="/seller/products?filter=rejected" class="btn-secondary" style="font-size:13px;padding:6px 12px;">Rejeitados</a>
  </div>
  <div class="table-container">
    <table class="admin-table">
      <thead><tr><th>Produto</th><th>Preço</th><th>Categoria</th><th>Status</th><th>Data</th><th>Ações</th></tr></thead>
      <tbody>
        <% if (products.length === 0) { %><tr><td colspan="6" class="empty-row">Nenhum produto</td></tr><% } %>
        <% products.forEach(p => { %>
          <tr>
            <td class="product-cell">
              <div class="product-cell-info">
                <% if (p.image) { %><img src="<%= p.image %>" alt="" class="thumb"><% } else { %><div class="thumb thumb-placeholder"><i class="fas fa-image"></i></div><% } %>
                <span class="product-name-cell"><%= p.name %></span>
              </div>
            </td>
            <td class="price-cell"><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(p.price) %></td>
            <td><%= p.category_name || '-' %></td>
            <td>
              <% if (p.status === 'active') { %><span class="status-badge active">Aprovado</span>
              <% } else if (p.status === 'pending') { %><span class="status-badge" style="background:#fff3cd;color:#856404;">Pendente</span>
              <% } else if (p.status === 'rejected') { %><span class="status-badge" style="background:#fdecea;color:#e74c3c;">Rejeitado</span>
              <% } else { %><span class="status-badge inactive">Inativo</span><% } %>
            </td>
            <td><%= new Date(p.created_at).toLocaleDateString('pt-BR') %></td>
            <td class="actions-cell">
              <a href="/seller/products/edit/<%= p.id %>" class="btn-icon" title="Editar"><i class="fas fa-edit"></i></a>
              <form action="/seller/products/clone/<%= p.id %>" method="POST" class="inline-form">
                <button type="submit" class="btn-icon" style="color:#7c4dff;" title="Clonar"><i class="fas fa-copy"></i></button>
              </form>
              <% if (p.status === 'rejected') { %>
                <form action="/seller/products/review-request/<%= p.id %>" method="POST" class="inline-form">
                  <button type="submit" class="btn-icon" style="color:#e65100;" title="Solicitar revisão"><i class="fas fa-sync"></i></button>
                </form>
              <% } %>
              <form action="/seller/products/delete/<%= p.id %>" method="POST" class="inline-form" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-icon btn-delete" title="Excluir"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/seller-footer') %>