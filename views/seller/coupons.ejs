<%- include('../partials/admin-header') %>

<div class="dashboard-header">
  <h1><i class="fas fa-ticket-alt"></i> Meus Cupons de Desconto</h1>
  <p>Crie cupons promocionais para seus produtos</p>
</div>

<% if (req.query.erro) { %><div style="background:#fdecea;color:#c62828;padding:10px 16px;border-radius:6px;margin-bottom:16px;"><%= req.query.erro %></div><% } %>

<div class="form-card" style="margin-bottom:20px;">
  <h3>Novo Cupom</h3>
  <form method="POST" action="/seller/coupons/new" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
    <div class="form-group"><label>Código</label><input type="text" name="code" class="admin-input" placeholder="PROMO10" required style="text-transform:uppercase;"></div>
    <div class="form-group"><label>Tipo</label><select name="type" class="admin-select"><option value="percentage">Porcentagem (%)</option><option value="fixed">Valor Fixo (R$)</option></select></div>
    <div class="form-group"><label>Valor</label><input type="number" name="value" class="admin-input" step="0.01" min="0" required></div>
    <div class="form-group"><label>Pedido Mínimo (R$)</label><input type="number" name="min_order" class="admin-input" step="0.01" min="0" value="0"></div>
    <div class="form-group"><label>Usos Máximos (0 = ilimitado)</label><input type="number" name="max_uses" class="admin-input" min="0" value="0"></div>
    <div class="form-group"><label>Expira em</label><input type="date" name="expires_at" class="admin-input"></div>
    <div style="grid-column:1/-1;"><button type="submit" class="btn-primary"><i class="fas fa-plus"></i> Criar Cupom</button></div>
  </form>
</div>

<div style="overflow-x:auto;">
<table class="admin-table">
  <thead>
    <tr>
      <th>Código</th>
      <th>Tipo</th>
      <th>Valor</th>
      <th>Mínimo</th>
      <th>Usos</th>
      <th>Expira</th>
      <th>Status</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% if (coupons.length === 0) { %>
      <tr><td colspan="8" class="empty-row">Nenhum cupom criado</td></tr>
    <% } %>
    <% coupons.forEach(function(c) { %>
      <tr>
        <td><strong style="font-family:monospace;"><%= c.code %></strong></td>
        <td><%= c.type === 'percentage' ? '%' : 'R$' %></td>
        <td><%= c.type === 'percentage' ? c.value + '%' : new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(c.value) %></td>
        <td><%= c.min_order > 0 ? new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(c.min_order) : '-' %></td>
        <td><%= c.used_count %><%= c.max_uses > 0 ? '/' + c.max_uses : '' %></td>
        <td><%= c.expires_at ? new Date(c.expires_at).toLocaleDateString('pt-BR') : '-' %></td>
        <td><span class="status-badge <%= c.active ? 'active' : 'inactive' %>"><%= c.active ? 'Ativo' : 'Inativo' %></span></td>
        <td>
          <form method="POST" action="/seller/coupons/delete/<%= c.id %>" style="display:inline;" onsubmit="return confirm('Excluir cupom?')">
            <button class="btn-small" style="background:#fff;color:#c62828;border:1px solid #ffcdd2;"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
</div>

<%- include('../partials/admin-footer') %>