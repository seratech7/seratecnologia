<%- include('../partials/admin-header') %>

<div class="dashboard-header">
  <h1><i class="fas fa-shopping-bag"></i> Minhas Vendas</h1>
  <p>Histórico de vendas dos seus produtos</p>
</div>

<% if (sales.length === 0) { %>
<div style="text-align:center;padding:60px;color:#999;">
  <i class="fas fa-shopping-bag" style="font-size:48px;opacity:0.3;margin-bottom:16px;"></i>
  <p>Nenhuma venda ainda</p>
</div>
<% } else { %>
<div style="overflow-x:auto;">
<table class="admin-table">
  <thead>
    <tr>
      <th>Produto</th>
      <th>Valor</th>
      <th>Comprador</th>
      <th>Contato</th>
      <th>Status</th>
      <th>Data</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% sales.forEach(function(v) { %>
    <tr>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
        <strong><%= v.product_code %></strong><br>
        <span style="font-size:13px;color:#666;"><%= v.product_name %></span>
      </td>
      <td style="font-weight:700;color:#1565c0;">
        <%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(v.product_price) %>
      </td>
      <td>
        <strong><%= v.buyer_name %></strong><br>
        <span style="font-size:12px;color:#999;"><%= v.buyer_document %></span>
      </td>
      <td>
        <a href="https://wa.me/55<%= v.buyer_phone.replace(/\D/g,'') %>" target="_blank" style="text-decoration:none;">
          <i class="fab fa-whatsapp" style="color:#25d366;"></i>
        </a>
        <a href="mailto:<%= v.buyer_email %>" style="margin-left:4px;text-decoration:none;color:#666;">
          <i class="fas fa-envelope"></i>
        </a>
      </td>
      <td>
        <form method="POST" action="/seller/sales/status/<%= v.id %>" style="display:flex;align-items:center;gap:4px;">
          <select name="status" style="padding:4px 8px;border:1px solid #ddd;border-radius:4px;font-size:12px;" onchange="this.form.submit()">
            <option value="pending" <%= v.status === 'pending' ? 'selected' : '' %>>Pendente</option>
            <option value="paid" <%= v.status === 'paid' ? 'selected' : '' %>>Pago</option>
            <option value="shipped" <%= v.status === 'shipped' ? 'selected' : '' %>>Enviado</option>
            <option value="delivered" <%= v.status === 'delivered' ? 'selected' : '' %>>Entregue</option>
            <option value="cancelled" <%= v.status === 'cancelled' ? 'selected' : '' %>>Cancelado</option>
          </select>
        </form>
      </td>
      <td style="font-size:12px;color:#666;white-space:nowrap;"><%= v.created_at %></td>
      <td>
        <a href="#" onclick='alert("Comprador: <%= v.buyer_name.replace(/'/g,"") %>\nEndereço: <%= v.buyer_address.replace(/'/g,"") %>")' class="btn-small" style="padding:4px 8px;font-size:11px;">
          <i class="fas fa-eye"></i>
        </a>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>
</div>

<% if (totalPages > 1) { %>
<div style="display:flex;gap:8px;justify-content:center;margin-top:20px;">
  <% for(var p=1;p<=totalPages;p++){ %>
    <a href="/seller/sales?page=<%= p %>" class="btn-small" style="<%= p===page?'background:var(--primary);color:#fff;':'' %>min-width:36px;text-align:center;text-decoration:none;"><%= p %></a>
  <% } %>
</div>
<% } %>
<% } %>

<%- include('../partials/admin-footer') %>