<%- include('../partials/seller-header') %>

<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-user-cog"></i> Meu Perfil</h1>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>

  <div class="form-card">
    <form action="/seller/profile" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Nome *</label>
          <input type="text" id="name" name="name" value="<%= seller.name %>" required>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" value="<%= seller.email %>" required>
        </div>
      </div>

      <div class="form-group">
        <label for="phone">Telefone</label>
        <input type="text" id="phone" name="phone" value="<%= seller.phone || '' %>" placeholder="(11) 99999-8888">
      </div>

      <div class="form-group">
        <label for="whatsapp">WhatsApp (com DDI e DDD, apenas números)</label>
        <input type="text" id="whatsapp" name="whatsapp" value="<%= seller.whatsapp || '' %>" placeholder="5511999998888">
      </div>

      <div class="form-group">
        <label for="pix_key">Chave PIX (CPF, CNPJ, email, telefone ou aleatória)</label>
        <input type="text" id="pix_key" name="pix_key" value="<%= seller.pix_key || '' %>" placeholder="CPF ou chave aleatória">
        <span style="font-size:12px;color:#888;">Essa chave será usada para receber pagamentos dos produtos que vender</span>
      </div>

      <div style="border-top:1px solid #eee;margin:16px 0;"></div>
      <h4 style="margin:0 0 12px;"><i class="fas fa-credit-card"></i> Mercado Pago</h4>
      <% if (seller.mp_connected) { %>
        <div style="background:#e8f5e9;color:#2e7d32;padding:12px 16px;border-radius:8px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
          <span><i class="fas fa-check-circle"></i> Conta Mercado Pago conectada</span>
          <form method="POST" action="/seller/mercadopago/disconnect" style="margin:0;">
            <button type="submit" class="btn-small" style="background:#fff;color:#c62828;border:1px solid #ffcdd2;">Desconectar</button>
          </form>
        </div>
      <% } else { %>
        <div style="background:#fff3e0;padding:12px 16px;border-radius:8px;">
          <p style="margin:0 0 8px;font-size:14px;"><i class="fas fa-info-circle"></i> Conecte sua conta Mercado Pago para receber pagamentos direto pelo marketplace.</p>
          <a href="/seller/mercadopago/auth" class="btn-small" style="background:#009ee3;color:#fff;text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
            <i class="fas fa-link"></i> Conectar Mercado Pago
          </a>
        </div>
      <% } %>

      <div style="border-top:1px solid #eee;margin:16px 0;"></div>
      <h4 style="margin:0 0 12px;"><i class="fas fa-bell"></i> Notificações de Vendas</h4>

      <div class="form-group">
        <label for="notify_whatsapp">Notificar via WhatsApp (número com DDI)</label>
        <input type="text" id="notify_whatsapp" name="notify_whatsapp" value="<%= seller.notify_whatsapp || '' %>" placeholder="5511999998888">
        <span style="font-size:12px;color:#888;">A cada venda, você receberá um link para enviar notificação no WhatsApp</span>
      </div>

      <div class="form-group">
        <label for="notify_signal">Notificar via Signal (número com DDI)</label>
        <input type="text" id="notify_signal" name="notify_signal" value="<%= seller.notify_signal || '' %>" placeholder="5511999998888">
        <span style="font-size:12px;color:#888;">A cada venda, você receberá um link para enviar notificação no Signal</span>
      </div>

      <div style="border-top:1px solid #eee;margin:16px 0;"></div>

      <div class="form-group">
        <label for="website">Site / Loja online</label>
        <input type="text" id="website" name="website" value="<%= seller.website || '' %>" placeholder="https://meusite.com">
      </div>

      <div class="form-group">
        <label for="bio">Sobre você / Sua loja</label>
        <textarea id="bio" name="bio" rows="4" placeholder="Fale um pouco sobre sua loja..."><%= seller.bio || '' %></textarea>
      </div>

      <div class="form-group">
        <label for="avatar">Foto do perfil (avatar)</label>
        <% if (seller.avatar) { %>
          <div class="current-image">
            <img src="<%= seller.avatar %>" alt="Avatar atual" style="max-width: 100px; border-radius: 50%;">
            <p>Avatar atual. Envie um novo para substituir.</p>
          </div>
        <% } %>
        <input type="file" id="avatar" name="avatar" accept="image/*">
      </div>

      <div class="info-box">
        <i class="fas fa-info-circle"></i>
        <p>Seu perfil é público. Clientes veem suas informações ao visitar seus produtos.</p>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Salvar Perfil</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/seller-footer') %>
