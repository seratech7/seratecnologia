<%- include('../partials/seller-header') %>
<div class="admin-content">
  <div class="page-header">
    <h1><i class="fas fa-cog"></i> Configurações</h1>
  </div>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <div class="form-card">
    <form method="POST" action="/seller/configuracoes" class="admin-form">
      <h3>Notificações</h3>
      <div class="form-group" style="margin:12px 0;">
        <label><input type="checkbox" name="notify_email_sale" value="1" <%= seller && seller.notify_email_sale ? 'checked' : '' %>> Receber email quando vender</label>
      </div>
      <div class="form-group" style="margin:12px 0;">
        <label><input type="checkbox" name="notify_email_approve" value="1" <%= seller && seller.notify_email_approve ? 'checked' : '' %>> Receber email quando produto for aprovado</label>
      </div>
      <div class="form-group" style="margin:12px 0;">
        <label><input type="checkbox" name="notify_whatsapp_sale" value="1" <%= seller && seller.notify_whatsapp_sale ? 'checked' : '' %>> Receber WhatsApp quando vender</label>
      </div>
      <p style="font-size:13px;color:#666;margin-top:16px;"><i class="fas fa-info-circle"></i> As metas agora são definidas pelo administrador. <a href="/seller/placar">Veja o placar atual</a>.</p>
      <div class="form-actions">
        <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Salvar</button>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/seller-footer') %>